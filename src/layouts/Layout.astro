---
import '../styles/global.css';

interface Props {
  title: string;
  description: string;
  ogType?: 'website' | 'article';
  publishedAt?: Date;
  updatedAt?: Date;
  jsonLd?: Record<string, unknown>;
}

const {
  title,
  description,
  ogType = 'website',
  publishedAt,
  updatedAt,
  jsonLd,
} = Astro.props;

const siteName = 'Intent Alpha';
const canonical = new URL(Astro.url.pathname, Astro.site).toString();
const fullTitle = title === siteName ? title : `${title} — ${siteName}`;

// Issue stamp at the masthead — derived from the first day the site shipped
const issueLabel = 'Vol. 01';
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />
    <title>{fullTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="alternate" type="application/rss+xml" title={`${siteName} RSS`} href="/rss.xml" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      rel="stylesheet"
      href="https://fonts.googleapis.com/css2?family=Fraunces:ital,opsz,wght,SOFT,WONK@0,9..144,300..600,30..100,0..1;1,9..144,300..600,30..100,0..1&family=Inter:wght@300..700&family=JetBrains+Mono:wght@400..600&display=swap"
    />

    <meta property="og:type" content={ogType} />
    <meta property="og:title" content={fullTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:site_name" content={siteName} />
    {publishedAt && <meta property="article:published_time" content={publishedAt.toISOString()} />}
    {updatedAt && <meta property="article:modified_time" content={updatedAt.toISOString()} />}

    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={fullTitle} />
    <meta name="twitter:description" content={description} />

    {jsonLd && <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />}
  </head>
  <body>
    <header class="site-header">
      <div class="inner">
        <a class="brand" href="/">Intent<span class="slash"> // </span>Alpha</a>
        <nav>
          <a href="/articles/">Dispatches</a>
          <a href="/companies/">Companies</a>
          <a href="/about/">About</a>
        </nav>
        <span class="issue">{issueLabel}</span>
      </div>
    </header>
    <main>
      <slot />
    </main>
    <footer class="site-footer">
      <div class="inner">
        <span>Intent // Alpha · Vol. 01</span>
        <span>Hiring signals → company direction. Not investment advice.</span>
        <a href="/rss.xml">RSS</a>
      </div>
    </footer>
  </body>
</html>
