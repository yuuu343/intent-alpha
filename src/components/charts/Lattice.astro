---
// Lattice — intent–alpha lattice.
// 2D matrix of topics positioned by (Do, Say) = (research/eng job count, arxiv
// paper count). 4 quadrants divided by threshold rules. Each topic is a
// vermillion dot + Fraunces italic label. Q4 (Do > Say — hiring before
// publishing) is the editorially featured quadrant.
//
// Hand-crafted SVG, no chart-lib. Same register as Heatmap / BarChart /
// Sparkline: cream + Fraunces + single vermillion accent.

interface Topic {
  topic: string;
  jobs: number;
  arxiv: number;
  quadrant: 'Q1' | 'Q2' | 'Q3' | 'Q4';
  sampleJobs?: { title: string; url: string; department: string | null }[];
  sampleArxiv?: { title: string; url: string; published: string }[];
}

interface Props {
  lab: string;
  topics: Topic[];
  thresholds: { jobs: number; arxiv: number };
  totals: { jobs: number; researchJobs: number; arxiv: number };
  caption?: string;
  compact?: boolean;
}

const { lab, topics, thresholds, totals, caption, compact = false } = Astro.props;

const W = 820;
const H = compact ? 420 : 560;
const PAD_L = 80;
const PAD_R = 50;
const PAD_T = 56;
const PAD_B = 70;
const GW = W - PAD_L - PAD_R;
const GH = H - PAD_T - PAD_B;

const maxJobs  = Math.max(1, ...topics.map((t) => t.jobs));
const maxArxiv = Math.max(1, ...topics.map((t) => t.arxiv));

const xScale = (jobs: number)  => PAD_L + (Math.log(jobs  + 1) / Math.log(maxJobs  + 1)) * GW;
const yScale = (arxiv: number) => PAD_T + GH - (Math.log(arxiv + 1) / Math.log(maxArxiv + 1)) * GH;

const xThresh = xScale(thresholds.jobs);
const yThresh = yScale(thresholds.arxiv);

const dotR = (t: Topic) => 4 + Math.sqrt(t.jobs + t.arxiv) * 0.9;

const TOPIC_LABEL: Record<string, string> = {
  post_training: 'post-training',
  pre_training: 'pre-training',
  interpretability: 'interpretability',
  alignment_safety: 'alignment',
  agents: 'agents',
  inference_serving: 'inference',
  multimodal: 'multimodal',
  evaluation: 'evaluation',
  compute_infra: 'compute',
  data_quality: 'data',
  security_eng: 'security',
  applied_fde: 'applied AI',
};

const QUADRANT_LABELS = [
  { x: PAD_L + 14,          y: PAD_T + 18,       anchor: 'start' as const, label: 'Say > Do',  sub: 'discourse without fresh hiring',     featured: false },
  { x: PAD_L + GW - 14,     y: PAD_T + 18,       anchor: 'end' as const,   label: 'Say + Do',  sub: 'core staffed research',              featured: false },
  { x: PAD_L + 14,          y: PAD_T + GH - 6,   anchor: 'start' as const, label: 'off-field', sub: 'low signal both axes',               featured: false },
  { x: PAD_L + GW - 14,     y: PAD_T + GH - 6,   anchor: 'end' as const,   label: 'Do > Say',  sub: 'hiring leads publishing',            featured: true  },
];
---

<figure class={`lattice-fig${compact ? ' lattice-fig--compact' : ''}`}>
  <svg class="lattice" viewBox={`0 0 ${W} ${H}`} preserveAspectRatio="xMidYMid meet" role="img" aria-label={caption ?? `${lab} intent–alpha lattice`}>
    <title>{caption ?? `${lab} intent–alpha lattice`}</title>

    <rect class="lat-bg" x={PAD_L} y={PAD_T} width={GW} height={GH}/>

    {/* Threshold rules first (under axes) */}
    <line class="lat-thresh" x1={xThresh} y1={PAD_T} x2={xThresh} y2={PAD_T + GH}/>
    <line class="lat-thresh" x1={PAD_L} y1={yThresh} x2={PAD_L + GW} y2={yThresh}/>

    {/* Axes */}
    <line class="lat-axis" x1={PAD_L} y1={PAD_T + GH} x2={PAD_L + GW} y2={PAD_T + GH}/>
    <line class="lat-axis" x1={PAD_L} y1={PAD_T} x2={PAD_L} y2={PAD_T + GH}/>

    {/* Axis labels */}
    <text class="lat-axis-label" x={PAD_L + GW / 2} y={H - 22} text-anchor="middle">Do — research / engineering jobs (log)</text>
    <g transform={`translate(20, ${PAD_T + GH / 2}) rotate(-90)`}>
      <text class="lat-axis-label" text-anchor="middle">Say — arxiv papers (log)</text>
    </g>

    {/* Quadrant labels */}
    {QUADRANT_LABELS.map((q) => (
      <g>
        <text class={`lat-quad-label${q.featured ? ' lat-quad-label--featured' : ''}`} x={q.x} y={q.y} text-anchor={q.anchor}>{q.label}</text>
        <text class="lat-quad-sub" x={q.x} y={q.y + 14} text-anchor={q.anchor}>{q.sub}</text>
      </g>
    ))}

    {/* Topic dots + labels */}
    {topics.map((t, i) => {
      const cx = xScale(t.jobs);
      const cy = yScale(t.arxiv);
      const r = dotR(t);
      const labelText = TOPIC_LABEL[t.topic] ?? t.topic;
      const onLeft = cx < PAD_L + GW * 0.5;
      const labelOffsetX = onLeft ? r + 7 : -r - 7;
      const labelAnchor = onLeft ? 'start' : 'end';
      const delay = i * 60;
      return (
        <g class={`lat-topic lat-topic--${t.quadrant.toLowerCase()}`} style={`animation-delay: ${delay}ms;`}>
          <circle class="lat-dot" cx={cx} cy={cy} r={r}/>
          <text class="lat-topic-label" x={cx + labelOffsetX} y={cy + 4} text-anchor={labelAnchor}>{labelText}</text>
          <title>{labelText} — {t.jobs} jobs · {t.arxiv} papers ({t.quadrant})</title>
        </g>
      );
    })}
  </svg>

  {caption && <figcaption class="lattice-caption">{caption}</figcaption>}
</figure>

<style>
  .lattice-fig {
    margin: 0;
    overflow-x: auto;
  }
  .lattice {
    width: 100%;
    height: auto;
    min-width: 600px;
    color: var(--fg);
    display: block;
  }
  .lat-bg {
    fill: var(--bg);
  }
  .lat-axis {
    stroke: var(--rule);
    stroke-width: 0.7;
    vector-effect: non-scaling-stroke;
  }
  .lat-thresh {
    stroke: var(--accent);
    stroke-width: 0.5;
    stroke-dasharray: 2 3;
    vector-effect: non-scaling-stroke;
    opacity: 0.55;
  }
  .lat-axis-label {
    font-family: var(--font-mono);
    font-size: 13px;
    text-transform: uppercase;
    letter-spacing: 0.10em;
    fill: var(--fg-muted);
    font-weight: 500;
  }
  .lat-quad-label {
    font-family: var(--font-mono);
    font-size: 15px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    fill: var(--fg-soft);
    opacity: 0.9;
  }
  .lat-quad-label--featured {
    fill: var(--accent);
    font-weight: 700;
    opacity: 1;
  }
  .lat-quad-sub {
    font-family: var(--font-mono);
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    fill: var(--fg-faint);
    font-weight: 500;
  }
  .lat-topic {
    animation: lat-fade-in 700ms cubic-bezier(0.16, 1, 0.3, 1) both;
  }
  .lat-dot {
    fill: var(--accent);
    fill-opacity: 0.55;
    stroke: var(--accent);
    stroke-width: 1.2;
    vector-effect: non-scaling-stroke;
    transition: fill-opacity 160ms ease, r 160ms ease;
  }
  .lat-topic--q4 .lat-dot {
    fill-opacity: 0.85;
    stroke: var(--accent-deep, var(--accent));
    stroke-width: 1.6;
  }
  .lat-topic--q1 .lat-dot {
    fill-opacity: 0.75;
  }
  .lat-topic--q3 .lat-dot {
    fill-opacity: 0.18;
    stroke-width: 0.8;
  }
  .lat-topic:hover .lat-dot {
    fill-opacity: 1;
  }
  .lat-topic-label {
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 500;
    fill: var(--fg-soft);
    pointer-events: none;
    letter-spacing: 0.01em;
  }
  .lat-topic--q4 .lat-topic-label,
  .lat-topic--q1 .lat-topic-label {
    fill: var(--fg);
    font-weight: 600;
  }
  .lat-topic--q3 .lat-topic-label {
    fill: var(--fg-faint);
  }
  @keyframes lat-fade-in {
    from { opacity: 0; transform: translateY(6px); }
    to   { opacity: 1; transform: translateY(0);   }
  }
  @media (prefers-reduced-motion: reduce) {
    .lat-topic { animation: none; }
  }
  .lattice-caption {
    margin-top: 0.85rem;
    font-family: var(--font-mono);
    font-size: var(--fs-meta);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--fg-muted);
    text-align: center;
  }
</style>
