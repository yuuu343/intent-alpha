---
// Sparkline — tiny inline trend line (vermillion, ~120 × 30 SVG).
// Used on company pages to show hiring count over snapshot history.
// With 2 data points it's a single segment — placeholder until snapshots
// accrue, but visually signals "we measure over time".

interface Point {
  date: string;
  value: number;
}

interface Props {
  points: Point[];
  width?: number;
  height?: number;
  showDots?: boolean;
}

const { points, width = 130, height = 32, showDots = true } = Astro.props;

const W = width;
const H = height;
const P = 3;
const N = points.length;

const xs = points.map((_, i) =>
  N <= 1 ? W / 2 : P + (i / (N - 1)) * (W - 2 * P)
);
const values = points.map((p) => p.value);
const minV = Math.min(...values);
const maxV = Math.max(...values);
const range = Math.max(1, maxV - minV);
const ys = values.map((v) =>
  H - P - ((v - minV) / range) * (H - 2 * P)
);

const pathD = points
  .map((_, i) => `${i === 0 ? 'M' : 'L'}${xs[i].toFixed(2)},${ys[i].toFixed(2)}`)
  .join(' ');

// Closed area path for the fill below the line (anchors at H-P on both ends).
const baseY = (H - P).toFixed(2);
const areaD = N > 1
  ? `M${xs[0].toFixed(2)},${baseY} L${pathD.slice(1)} L${xs[N - 1].toFixed(2)},${baseY} Z`
  : '';

// Peak / trough indices — used to mark the extreme points more prominently.
let peakIdx = 0;
let troughIdx = 0;
for (let i = 1; i < N; i++) {
  if (values[i] > values[peakIdx]) peakIdx = i;
  if (values[i] < values[troughIdx]) troughIdx = i;
}

const titles = points.map((p) => `${p.date}: ${p.value.toLocaleString()}`).join(' · ');
---
<svg class="sparkline" viewBox={`0 0 ${W} ${H}`} preserveAspectRatio="none" role="img" aria-label={titles}>
  <title>{titles}</title>
  {N > 1 && <path class="spark-area" d={areaD}/>}
  {N > 1 && <path class="spark-line" d={pathD}/>}
  {showDots && points.map((_, i) => {
    const isPeak = i === peakIdx && N > 1;
    return <circle class={`spark-dot${isPeak ? ' spark-dot--peak' : ''}`} cx={xs[i]} cy={ys[i]}/>;
  })}
</svg>

<style>
  .sparkline {
    width: 100%;
    max-width: 130px;
    height: 32px;
    display: inline-block;
    overflow: visible;
  }
  .spark-area {
    fill: var(--accent);
    fill-opacity: 0.13;
    stroke: none;
  }
  .spark-line {
    stroke: var(--accent);
    stroke-width: var(--spark-stroke, 1.5);
    fill: none;
    vector-effect: non-scaling-stroke;
    stroke-linecap: round;
    stroke-linejoin: round;
  }
  .spark-dot {
    fill: var(--accent);
    r: var(--spark-dot, 1.7);
  }
  .spark-dot--peak {
    r: calc(var(--spark-dot, 1.7) * 1.7);
    fill: var(--accent-deep, var(--accent));
    stroke: var(--bg);
    stroke-width: 1;
    vector-effect: non-scaling-stroke;
  }
  /* Mobile: thicker stroke and larger dots for outdoor / low-brightness viewing. */
  @media (max-width: 640px) {
    .sparkline { --spark-stroke: 2.2; --spark-dot: 2.0; }
  }
</style>
