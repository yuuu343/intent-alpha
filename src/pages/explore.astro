---
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import Heatmap from '../components/charts/Heatmap.astro';
import { THEMES } from '../data/themes';
import fs from 'node:fs';
import path from 'node:path';

const allCompanies = (await getCollection('companies'))
  .filter((c) => c.data.aiRelevance !== 'non_ai')
  .sort((a, b) => a.data.name.localeCompare(b.data.name));

type ExploreJob = {
  id: string;
  title: string;
  companySlug: string;
  companyName: string;
  dept: string;
  location: string;
  url: string;
  date: string;
};

const SNAPSHOTS = path.resolve(process.cwd(), 'data', 'snapshots');
const allJobs: ExploreJob[] = [];
const companyTotals = new Map<string, number>();
let latestSnapshot: string | null = null;

for (const c of allCompanies) {
  const dir = path.join(SNAPSHOTS, c.id);
  if (!fs.existsSync(dir)) continue;
  const files = fs.readdirSync(dir).filter((f) => /^\d{4}-\d{2}-\d{2}\.json$/.test(f)).sort();
  if (!files.length) continue;
  const newest = files[files.length - 1];
  if (!latestSnapshot || newest > latestSnapshot) latestSnapshot = newest;
  const snap = JSON.parse(fs.readFileSync(path.join(dir, newest), 'utf8'));
  const jobs = (snap.jobs ?? []) as Array<{ id?: string | number; title?: string; department?: string | null; location?: string | null; url?: string | null; updated_at?: string | null }>;
  companyTotals.set(c.id, jobs.length);
  for (const j of jobs) {
    allJobs.push({
      id: String(j.id ?? ''),
      title: j.title || '',
      companySlug: c.id,
      companyName: c.data.name,
      dept: j.department || '',
      location: j.location || '',
      url: j.url || '',
      date: (j.updated_at || '').slice(0, 10),
    });
  }
}

const fetchedCompanies = allCompanies.filter((c) => companyTotals.has(c.id));
fetchedCompanies.sort((a, b) => (companyTotals.get(b.id) ?? 0) - (companyTotals.get(a.id) ?? 0));

// Initial heatmap matrix (full dataset, before any filter)
const initialMatrix: { row: string; col: string; value: number }[] = [];
for (const c of fetchedCompanies) {
  const cJobs = allJobs.filter((j) => j.companySlug === c.id);
  for (const t of THEMES) {
    const count = cJobs.filter((j) => t.regex.test(j.title)).length;
    if (count > 0) initialMatrix.push({ row: c.id, col: t.slug, value: count });
  }
}

const heatmapRows = fetchedCompanies.map((c) => ({ id: c.id, label: c.data.name }));
const heatmapCols = THEMES.map((t) => ({ id: t.slug, label: t.name }));

const exploreData = {
  jobs: allJobs,
  themes: THEMES.map((t) => ({ slug: t.slug, name: t.name, regex: t.regex.source })),
  companies: fetchedCompanies.map((c) => ({ slug: c.id, name: c.data.name, total: companyTotals.get(c.id) ?? 0 })),
};

const fmtDate = (s: string | null) => s ? s.replace('.json', '').replaceAll('-', '.') : '—';
---
<Layout
  title="Explore"
  description="Filter, sort, and explore the full set of open AI roles aggregated by Intent Alpha — companies × themes × departments × locations."
  spineGlyph="⨂"
  bgEquation={`J ⊂ Companies ⨂ Themes`}
>
  <section class="hero" style="border-bottom: 0; padding-bottom: 1.25rem;">
    <span class="meta meta--accent">The product space</span>
    <h1>Explore.</h1>
    <p class="lede">
      Every open role visible to our adapters, filterable. Companies × themes ×
      departments × locations × free text. The heatmap above the table reflows as
      you filter; rows in the table link to the original posting on the company's
      board.
    </p>
  </section>

  <div class="stats stats--small">
    <div class="item">
      <span class="num"><em><span id="explore-count">{allJobs.length.toLocaleString()}</span></em></span>
      <span class="lbl">Open roles (filtered)</span>
    </div>
    <div class="item">
      <span class="num">{allJobs.length.toLocaleString()}</span>
      <span class="lbl">Total in panorama</span>
    </div>
    <div class="item">
      <span class="num">{fetchedCompanies.length}</span>
      <span class="lbl">Companies fetched</span>
    </div>
    <div class="item">
      <span class="num">{THEMES.length}</span>
      <span class="lbl">Themes mapped</span>
    </div>
    <div class="item">
      <span class="num num--date">{fmtDate(latestSnapshot)}</span>
      <span class="lbl">Latest snapshot</span>
    </div>
  </div>

  <div class="section-head">
    <h2>Distribution (live)</h2>
    <span class="count">cells reflow as filters change</span>
  </div>
  <p class="meta" style="margin-bottom: 1.5rem; color: var(--fg-muted); text-transform: none; letter-spacing: 0;">
    f(company, theme | filters) = matching role count. Cell shading scales with the count under the current filter set; click a cell to set the theme filter and re-scope.
  </p>
  <Heatmap
    rows={heatmapRows}
    cols={heatmapCols}
    cells={initialMatrix}
  />
  <p class="meta" style="margin: 0.75rem 0 1.5rem; color: var(--fg-muted); text-transform: none; letter-spacing: 0; text-align: right;">
    fill ∝ count^0.55 · scale recomputes per filter
  </p>

  <div class="section-head" style="margin-top: 2.5rem;">
    <h2>Filters</h2>
    <button id="explore-reset" type="button" class="explore-reset">Reset all</button>
  </div>

  <div class="explore-filters">
    <label class="flt">
      <span class="flt-lbl">Company</span>
      <select id="flt-company" class="flt-input">
        <option value="">all ({fetchedCompanies.length})</option>
        {fetchedCompanies.map((c) => <option value={c.id}>{c.data.name} ({companyTotals.get(c.id) ?? 0})</option>)}
      </select>
    </label>
    <label class="flt">
      <span class="flt-lbl">Theme</span>
      <select id="flt-theme" class="flt-input">
        <option value="">all ({THEMES.length})</option>
        {THEMES.map((t) => <option value={t.slug}>{t.name}</option>)}
      </select>
    </label>
    <label class="flt">
      <span class="flt-lbl">Department contains</span>
      <input id="flt-dept" class="flt-input" type="text" autocomplete="off" placeholder="e.g. safeguards"/>
    </label>
    <label class="flt">
      <span class="flt-lbl">Title contains</span>
      <input id="flt-title" class="flt-input" type="text" autocomplete="off" placeholder="e.g. forward deployed"/>
    </label>
  </div>

  <div class="explore-presets">
    <span class="meta" style="text-transform: uppercase; letter-spacing: 0.12em; color: var(--fg-muted); margin-right: 0.5rem;">Quick reads</span>
    <button type="button" class="preset-btn" data-preset='{"theme":"safety"}'>Alignment-coded only</button>
    <button type="button" class="preset-btn" data-preset='{"title":"forward deployed"}'>Forward Deployed (any company)</button>
    <button type="button" class="preset-btn" data-preset='{"title":"applied ai"}'>Applied AI</button>
    <button type="button" class="preset-btn" data-preset='{"theme":"agents"}'>Agents theme</button>
    <button type="button" class="preset-btn" data-preset='{"company":"anthropic","title":"beneficial deployments"}'>Beneficial Deployments at Anthropic</button>
  </div>

  <div class="section-head" style="margin-top: 2.5rem;">
    <h2>Postings</h2>
    <span class="count" id="explore-pagination">page 1</span>
  </div>

  <div class="explore-table-wrap">
    <table class="explore-table">
      <thead>
        <tr>
          <th class="col-title">Title (→ original posting)</th>
          <th class="col-company">Company</th>
          <th class="col-dept">Department</th>
          <th class="col-loc">Location</th>
          <th class="col-date">Updated</th>
        </tr>
      </thead>
      <tbody id="explore-tbody"></tbody>
    </table>
  </div>

  <div class="explore-pager">
    <button id="explore-prev" type="button" class="pager-btn">← prev</button>
    <span id="explore-pager-info" class="meta" style="text-transform: uppercase; letter-spacing: 0.12em; color: var(--fg-muted);"></span>
    <button id="explore-next" type="button" class="pager-btn">next →</button>
  </div>

  <article class="prose" style="margin-top: 4rem;">
    <h2>Notes on this page</h2>
    <p>
      All postings here are pulled from the same public ATS endpoints documented
      at <a href="/coverage/">/coverage</a>. Title links open the original posting
      on the company's board — we provide the navigation; the company's site
      shows you the description, requirements, and apply flow. Department,
      location, and updated-date come straight from each ATS without
      modification.
    </p>
    <p>
      The "Quick reads" presets are starting points, not editorial conclusions.
      Use them to anchor a filter combination, then refine. The dispatches
      under <a href="/articles/">Dispatches</a> are where we draw inferences
      from these same data; the
      <a href="/track-record/">Track Record</a> page is where those inferences
      are audited against their reversal conditions.
    </p>
  </article>
</Layout>

<script type="application/json" id="explore-data" set:html={JSON.stringify(exploreData)}></script>

<script is:inline>
  (function () {
    const PAGE_SIZE = 50;
    const raw = JSON.parse(document.getElementById('explore-data').textContent);
    const themes = raw.themes.map(function (t) { return { slug: t.slug, name: t.name, regex: new RegExp(t.regex, 'i') }; });
    const themeMap = Object.fromEntries(themes.map(function (t) { return [t.slug, t]; }));

    const state = { company: '', theme: '', dept: '', title: '', page: 0 };
    let lastFiltered = raw.jobs;

    function escape(s) {
      return String(s).replace(/[&<>"']/g, function (c) { return ({ '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;' })[c]; });
    }

    function applyFilters() {
      const dept = state.dept.toLowerCase();
      const title = state.title.toLowerCase();
      const themeRegex = state.theme && themeMap[state.theme] ? themeMap[state.theme].regex : null;
      return raw.jobs.filter(function (j) {
        if (state.company && j.companySlug !== state.company) return false;
        if (themeRegex && !themeRegex.test(j.title)) return false;
        if (dept && (j.dept || '').toLowerCase().indexOf(dept) === -1) return false;
        if (title && (j.title || '').toLowerCase().indexOf(title) === -1) return false;
        return true;
      });
    }

    function renderTable(filtered) {
      const total = filtered.length;
      const totalPages = Math.max(1, Math.ceil(total / PAGE_SIZE));
      if (state.page >= totalPages) state.page = totalPages - 1;
      if (state.page < 0) state.page = 0;
      const start = state.page * PAGE_SIZE;
      const slice = filtered.slice(start, start + PAGE_SIZE);
      const tbody = document.getElementById('explore-tbody');
      tbody.innerHTML = slice.map(function (j) {
        const titleHtml = j.url
          ? '<a href="' + escape(j.url) + '" rel="noopener" target="_blank">' + escape(j.title) + '</a>'
          : escape(j.title);
        return '<tr>'
          + '<td class="col-title">' + titleHtml + '</td>'
          + '<td class="col-company"><a href="/companies/' + escape(j.companySlug) + '/">' + escape(j.companyName) + '</a></td>'
          + '<td class="col-dept">' + escape(j.dept || '—') + '</td>'
          + '<td class="col-loc">' + escape(j.location || '—') + '</td>'
          + '<td class="col-date">' + escape(j.date || '—') + '</td>'
          + '</tr>';
      }).join('');
      document.getElementById('explore-count').textContent = total.toLocaleString();
      document.getElementById('explore-pagination').textContent = 'page ' + (state.page + 1) + ' of ' + totalPages;
      document.getElementById('explore-pager-info').textContent = total === 0
        ? 'no matches'
        : (start + 1) + '–' + Math.min(start + PAGE_SIZE, total) + ' of ' + total.toLocaleString();
      document.getElementById('explore-prev').disabled = state.page === 0;
      document.getElementById('explore-next').disabled = state.page >= totalPages - 1;
    }

    function renderHeatmap(filtered) {
      const cells = {};
      for (let i = 0; i < filtered.length; i++) {
        const j = filtered[i];
        for (let k = 0; k < themes.length; k++) {
          const t = themes[k];
          if (t.regex.test(j.title)) {
            const key = j.companySlug + '|' + t.slug;
            cells[key] = (cells[key] || 0) + 1;
          }
        }
      }
      let max = 0;
      for (const k in cells) if (cells[k] > max) max = cells[k];
      if (max === 0) max = 1;
      const cellEls = document.querySelectorAll('.hm-cell');
      for (let i = 0; i < cellEls.length; i++) {
        const cell = cellEls[i];
        const row = cell.getAttribute('data-row');
        const col = cell.getAttribute('data-col');
        const v = cells[row + '|' + col] || 0;
        const op = v === 0 ? 0 : 0.08 + 0.88 * Math.pow(v / max, 0.55);
        const bg = cell.querySelector('.hm-cell-bg');
        if (bg) bg.style.fillOpacity = op;
        const text = cell.querySelector('.hm-cell-text');
        if (text) {
          if (v > 0) {
            text.textContent = v;
            text.style.display = '';
          } else {
            text.style.display = 'none';
          }
        }
      }
    }

    function render() {
      lastFiltered = applyFilters();
      renderTable(lastFiltered);
      renderHeatmap(lastFiltered);
    }

    function syncControls() {
      document.getElementById('flt-company').value = state.company;
      document.getElementById('flt-theme').value = state.theme;
      document.getElementById('flt-dept').value = state.dept;
      document.getElementById('flt-title').value = state.title;
    }

    function bind() {
      document.getElementById('flt-company').addEventListener('change', function (e) { state.company = e.target.value; state.page = 0; render(); });
      document.getElementById('flt-theme').addEventListener('change', function (e) { state.theme = e.target.value; state.page = 0; render(); });

      let deptTimer; const deptEl = document.getElementById('flt-dept');
      deptEl.addEventListener('input', function (e) { clearTimeout(deptTimer); deptTimer = setTimeout(function () { state.dept = e.target.value; state.page = 0; render(); }, 150); });
      let titleTimer; const titleEl = document.getElementById('flt-title');
      titleEl.addEventListener('input', function (e) { clearTimeout(titleTimer); titleTimer = setTimeout(function () { state.title = e.target.value; state.page = 0; render(); }, 150); });

      document.getElementById('explore-reset').addEventListener('click', function () {
        state.company = ''; state.theme = ''; state.dept = ''; state.title = ''; state.page = 0;
        syncControls(); render();
      });
      document.getElementById('explore-prev').addEventListener('click', function () { state.page = Math.max(0, state.page - 1); render(); });
      document.getElementById('explore-next').addEventListener('click', function () { state.page = state.page + 1; render(); });

      document.querySelectorAll('.preset-btn').forEach(function (btn) {
        btn.addEventListener('click', function () {
          let p; try { p = JSON.parse(btn.getAttribute('data-preset')); } catch (e) { return; }
          state.company = p.company || '';
          state.theme = p.theme || '';
          state.dept = p.dept || '';
          state.title = p.title || '';
          state.page = 0;
          syncControls(); render();
        });
      });
    }

    bind();
    render();
  })();
</script>

<style>
  .explore-filters {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(13rem, 1fr));
    gap: 0.85rem 1.25rem;
    margin: 0 0 1.5rem;
  }
  .flt { display: flex; flex-direction: column; gap: 0.35rem; }
  .flt-lbl {
    font-family: var(--font-mono);
    font-size: var(--fs-meta);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--fg-muted);
  }
  .flt-input {
    font-family: var(--font-body);
    font-size: 0.95rem;
    padding: 0.5rem 0.65rem;
    background: var(--bg);
    color: var(--fg);
    border: 1px solid var(--rule);
    border-radius: 0;
    outline: none;
  }
  .flt-input:focus {
    border-color: var(--accent);
  }
  select.flt-input {
    appearance: auto;
  }
  .explore-reset {
    font-family: var(--font-mono);
    font-size: var(--fs-meta);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--fg-muted);
    background: transparent;
    border: 1px solid var(--rule);
    padding: 0.45rem 0.85rem;
    cursor: pointer;
  }
  .explore-reset:hover { color: var(--accent); border-color: var(--accent); }

  .explore-presets {
    display: flex;
    flex-wrap: wrap;
    gap: 0.5rem;
    align-items: center;
    margin: 0 0 1.5rem;
  }
  .preset-btn {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    letter-spacing: 0.04em;
    color: var(--fg-soft);
    background: var(--bg-deep);
    border: 1px solid var(--rule-soft);
    padding: 0.35rem 0.7rem;
    cursor: pointer;
    transition: color 180ms ease, border-color 180ms ease;
  }
  .preset-btn:hover { color: var(--accent); border-color: var(--accent); }

  .explore-table-wrap {
    overflow-x: auto;
    margin: 0 0 1rem;
  }
  .explore-table {
    width: 100%;
    min-width: 760px;
    border-collapse: collapse;
    font-size: 0.92rem;
    line-height: 1.45;
  }
  .explore-table th {
    text-align: left;
    font-family: var(--font-mono);
    font-size: 0.72rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--fg-muted);
    padding: 0.55rem 0.5rem;
    border-bottom: 1px solid var(--rule);
    background: var(--bg);
  }
  .explore-table td {
    padding: 0.6rem 0.5rem;
    border-bottom: 1px solid var(--rule-soft);
    vertical-align: top;
  }
  .explore-table .col-title { font-family: var(--font-display); font-size: 0.98rem; font-weight: 380; font-variation-settings: "opsz" 60, "SOFT" 60, "WONK" 1; min-width: 18rem; }
  .explore-table .col-title a { text-decoration: none; color: var(--fg); }
  .explore-table .col-title a:hover { color: var(--accent); }
  .explore-table .col-company { font-family: var(--font-display); font-style: italic; font-variation-settings: "opsz" 60, "SOFT" 60, "WONK" 1; color: var(--fg-soft); }
  .explore-table .col-company a { text-decoration: none; color: inherit; }
  .explore-table .col-company a:hover { color: var(--accent); }
  .explore-table .col-dept { font-family: var(--font-mono); font-size: 0.78rem; color: var(--fg-muted); }
  .explore-table .col-loc { font-family: var(--font-mono); font-size: 0.78rem; color: var(--fg-muted); }
  .explore-table .col-date { font-family: var(--font-mono); font-size: 0.78rem; color: var(--fg-faint); white-space: nowrap; }

  .explore-pager {
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 1rem;
    margin: 1rem 0 2rem;
  }
  .pager-btn {
    font-family: var(--font-mono);
    font-size: var(--fs-meta);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--fg-muted);
    background: transparent;
    border: 1px solid var(--rule);
    padding: 0.45rem 0.85rem;
    cursor: pointer;
  }
  .pager-btn:hover:not(:disabled) { color: var(--accent); border-color: var(--accent); }
  .pager-btn:disabled { opacity: 0.4; cursor: not-allowed; }
</style>
