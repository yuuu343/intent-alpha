---
import fs from 'node:fs';
import path from 'node:path';
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import { THEMES } from '../data/themes';
import Heatmap from '../components/charts/Heatmap.astro';
import Sparkline from '../components/charts/Sparkline.astro';

const articles = (await getCollection('articles', ({ data }) => !data.draft && !data.archived))
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());

const allCompanies = (await getCollection('companies'))
  .sort((a, b) => a.data.name.localeCompare(b.data.name));
const companies = allCompanies.filter((c) => c.data.aiRelevance !== 'non_ai');

// Per-company × per-theme matrix, computed at build time from the latest
// snapshot per company. Powers the homepage heatmap (the page's data anchor)
// and the stats / themes summaries below. Snapshot history per company
// (when multiple snapshots exist) feeds the inline sparkline next to each
// tracked-company row.
const SNAPSHOTS = path.resolve(process.cwd(), 'data', 'snapshots');
const matrixCells: { row: string; col: string; value: number }[] = [];
const companyTotals = new Map<string, number>();
const companyHistories = new Map<string, { date: string; value: number }[]>();
const themeTotals = new Map<string, number>();
let panoramaPostings = 0;
let panoramaCompanies = 0;
let latestSnapshotDate: string | null = null;

for (const c of companies) {
  const dir = path.join(SNAPSHOTS, c.id);
  if (!fs.existsSync(dir)) continue;
  const files = fs.readdirSync(dir).filter((f) => /^\d{4}-\d{2}-\d{2}\.json$/.test(f)).sort();
  if (!files.length) continue;
  const newest = files[files.length - 1];
  if (!latestSnapshotDate || newest > latestSnapshotDate) latestSnapshotDate = newest;
  // Snapshot history (date + count) — reads every snapshot file for this
  // company; cheap (typically 1–3 small JSON files) and only runs at build.
  if (files.length >= 2) {
    const history: { date: string; value: number }[] = [];
    for (const f of files) {
      try {
        const s = JSON.parse(fs.readFileSync(path.join(dir, f), 'utf8'));
        const count = typeof s.count === 'number' ? s.count : (Array.isArray(s.jobs) ? s.jobs.length : 0);
        history.push({ date: f.replace('.json', ''), value: count });
      } catch { /* skip */ }
    }
    if (history.length >= 2) companyHistories.set(c.id, history);
  }
  const snap = JSON.parse(fs.readFileSync(path.join(dir, newest), 'utf8'));
  const jobs = (snap.jobs ?? []) as { title?: string }[];
  panoramaCompanies++;
  panoramaPostings += snap.count ?? jobs.length;
  companyTotals.set(c.id, jobs.length);
  for (const t of THEMES) {
    const count = jobs.filter((j) => t.regex.test(j.title || '')).length;
    if (count > 0) {
      matrixCells.push({ row: c.id, col: t.slug, value: count });
      themeTotals.set(t.slug, (themeTotals.get(t.slug) ?? 0) + count);
    }
  }
}

const themeStats = THEMES.map((t) => ({
  ...t,
  total: themeTotals.get(t.slug) ?? 0,
}));

// Heatmap: companies sorted by fetched-role count, themes in canonical order
const fetchedCompanies = companies.filter((c) => (companyTotals.get(c.id) ?? 0) > 0);
fetchedCompanies.sort((a, b) => (companyTotals.get(b.id) ?? 0) - (companyTotals.get(a.id) ?? 0));
const heatmapRows = fetchedCompanies.map((c) => ({ id: c.id, label: c.data.name }));
const heatmapCols = THEMES.map((t) => ({ id: t.slug, label: t.name }));
const fmtSnapDate = (s: string | null) => s ? s.replace('.json', '').replaceAll('-', '.') : '—';

// α · observed — the front-page magnet. Forward prediction, not site
// description. Click target is /observed/<slug>/ (viz-first intermediate
// page) — NOT directly the deep dispatch. The funnel is:
//   homepage observation → viz-first page → deep dispatch
// Each step earns the next.
const observation = {
  date: '2026-04-30',
  headline: 'Anthropic is staffing the sales side',
  emphasis: 'of Claude products that haven\'t been announced.',
  numbers: [
    { value: '6', label: 'Federal AEs' },
    { value: '6', label: 'Beneficial Deployments AEs' },
    { value: '3', label: 'vertical plugin packs' },
    { value: '451', label: 'total Anthropic roles' },
  ],
  link: {
    href: '/observed/anthropic-vertical-claude/',
    label: 'See the data →',
  },
};

const description = 'Intent Alpha reads the public job boards of foundation labs, chip companies, and AI-adjacent platforms, and looks for what AI is becoming. Hypotheses with the hiring signals they rest on.';

const fmtDate = (d: Date) => d.toISOString().slice(0, 10).replace(/-/g, '.');
---
<Layout title="Intent Alpha" description={description} bgEquations={["e^(iπ) + 1 = 0", "L = − Σᵢ yᵢ log ŷᵢ"]}>
  <section class="obs-hero">
    <span class="meta meta--accent">α · observed {observation.date}</span>
    <h1 class="obs-headline">
      <span class="obs-line-1">{observation.headline}</span>
      <span class="obs-line-2">{observation.emphasis}</span>
    </h1>
    <div class="obs-numbers">
      {observation.numbers.map((n) => (
        <div class="obs-num-item">
          <span class="obs-num-value">{n.value}</span>
          <span class="obs-num-label">{n.label}</span>
        </div>
      ))}
    </div>
    <p class="obs-link">
      <a href={observation.link.href}>→ {observation.link.label}</a>
    </p>
    <p class="obs-tagline">
      Frontier AI labs are read here against their own hiring. The gap between
      what they <em>say</em> in public and what they <em>actually staff for</em> is
      the signal — the <em>intent–alpha gap</em>. Every dispatch is one
      measurement; the year-over-year record is the artifact.
    </p>
  </section>

  <section class="stats">
    <div class="item">
      <span class="num">{panoramaCompanies}</span>
      <span class="lbl">AI companies in panorama</span>
    </div>
    <div class="item">
      <span class="num">{panoramaPostings.toLocaleString()}</span>
      <span class="lbl">Open roles aggregated</span>
    </div>
    <div class="item">
      <span class="num"><em>{THEMES.length}</em></span>
      <span class="lbl">Themes mapped</span>
    </div>
    <div class="item">
      <span class="num">{articles.length}</span>
      <span class="lbl">Dispatches published</span>
    </div>
  </section>

  <div class="section-head">
    <h2>The Panorama</h2>
    <a href="/themes/" class="count" style="text-decoration: none;">All {THEMES.length} themes →</a>
  </div>
  <p class="meta" style="margin-bottom: 1.5rem; color: var(--fg-muted); text-transform: none; letter-spacing: 0;">
    Where the field puts its hires. {fetchedCompanies.length} companies × {THEMES.length} themes; cell shade is role count tagged by theme regex (cream → vermillion). Click any cell to open the theme; hover to read the count. Snapshots through {fmtSnapDate(latestSnapshotDate)}.
  </p>
  <Heatmap
    rows={heatmapRows}
    cols={heatmapCols}
    cells={matrixCells}
    cellHref={(_rowId, colId) => `/themes/${colId}/`}
  />
  <p class="meta" style="margin: 0.85rem 0 1.5rem; color: var(--fg-muted); text-transform: none; letter-spacing: 0; text-align: right;">
    f(company, theme) = matching roles · fill ∝ count^0.55
  </p>

  <div class="section-head">
    <h2>Latest Dispatches</h2>
    <span class="count">{articles.length} of {articles.length}</span>
  </div>
  {articles.length === 0 && (
    <p class="meta" style="padding: 1.5rem 0;">No dispatches yet — first ones land soon.</p>
  )}
  <div class="dispatch-list">
    {articles.map((a) => (
      <a class="dispatch" href={`/articles/${a.id}/`}>
        <div class="meta-col">
          <span class="meta meta--accent">{a.data.cycle ? `Cycle №${a.data.cycle}` : 'Cycle —'}</span>
          <span class="meta">{fmtDate(a.data.publishedAt)}</span>
          <span class="meta" style="color: var(--fg-soft);">{a.data.company}</span>
        </div>
        <div>
          <h3>{a.data.title}</h3>
          <p class="desc">{a.data.description}</p>
        </div>
        <div class="stamp-col">
          <span class={`stamp stamp--${a.data.confidence}`}>
            <span class="v">{a.data.confidence}</span>
            <span class="h">{a.data.horizon}</span>
          </span>
        </div>
      </a>
    ))}
  </div>

  <div class="section-head">
    <h2>Tracked</h2>
    <span class="count">№ 01–{String(companies.length).padStart(2, '0')}</span>
  </div>
  <div class="list-rows tracked-rows">
    {companies.map((c, i) => {
      const history = companyHistories.get(c.id);
      return (
        <a class="list-row tracked-row" href={`/companies/${c.id}/`}>
          <span class="name">{c.data.name}</span>
          <span class="desc">{c.data.sector ?? c.data.description.slice(0, 80)}</span>
          <span class="trend">
            {history && <Sparkline points={history} width={90} height={22} showDots={false}/>}
          </span>
          <span class="num">№ {String(i + 1).padStart(2, '0')}</span>
        </a>
      );
    })}
  </div>
</Layout>

<style>
  /* α · observed — front-page magnet. Designed to do its work above the
     fold: tagline → headline → numbers → click-through, all visible without
     scrolling on most viewports. */
  .obs-hero {
    max-width: var(--measure-full);
    padding-bottom: 2.5rem;
    border-bottom: var(--rule-thick) solid var(--rule);
    isolation: isolate;
  }
  .obs-headline {
    font-family: var(--font-display);
    font-weight: 360;
    letter-spacing: -0.025em;
    line-height: 1.04;
    margin: 1rem 0 1.5rem;
    max-width: 26ch;
    font-variation-settings: "opsz" 144, "SOFT" 50, "WONK" 1;
    animation: inner-from-left 1500ms cubic-bezier(0.16, 1, 0.3, 1) 250ms both;
  }
  .obs-line-1 {
    display: block;
    font-size: clamp(2rem, 5vw, 3.6rem);
    color: var(--fg-soft);
    font-style: italic;
    font-variation-settings: "opsz" 144, "SOFT" 100, "WONK" 1;
  }
  .obs-line-2 {
    display: block;
    font-size: clamp(2.4rem, 6.8vw, 5rem);
    color: var(--fg);
    margin-top: 0.2em;
    font-variation-settings: "opsz" 144, "SOFT" 30, "WONK" 1;
  }
  .obs-numbers {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(8.5rem, 1fr));
    gap: 1rem 2rem;
    padding: 1.25rem 0 1rem;
    border-top: 1px solid var(--rule-soft);
    border-bottom: 1px solid var(--rule-soft);
    margin: 0.5rem 0 1.25rem;
    animation: inner-from-below 1500ms cubic-bezier(0.16, 1, 0.3, 1) 600ms both;
  }
  .obs-num-item {
    display: flex;
    flex-direction: column;
    gap: 0.35rem;
  }
  .obs-num-value {
    font-family: var(--font-display);
    font-variation-settings: "opsz" 144, "SOFT" 30, "WONK" 1;
    font-weight: 380;
    font-size: clamp(1.8rem, 3.6vw, 2.6rem);
    line-height: 1;
    letter-spacing: -0.03em;
    color: var(--accent);
  }
  .obs-num-label {
    font-family: var(--font-mono);
    font-size: var(--fs-meta);
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--fg-muted);
  }
  .obs-link {
    margin: 0.5rem 0 1.5rem;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    letter-spacing: 0.04em;
  }
  .obs-link a {
    color: var(--accent);
    text-decoration: none;
    border-bottom: 1px solid var(--accent);
    padding-bottom: 0.1em;
  }
  .obs-link a:hover {
    color: var(--accent-deep);
    border-bottom-color: var(--accent-deep);
  }
  .obs-tagline {
    font-family: var(--font-display);
    font-style: italic;
    font-weight: 350;
    font-size: var(--fs-lead);
    line-height: 1.42;
    font-variation-settings: "opsz" 36, "SOFT" 50, "WONK" 0;
    max-width: 44rem;
    color: var(--fg-soft);
    margin-top: 1.5rem;
  }
  .obs-tagline em {
    color: var(--fg);
    font-variation-settings: "opsz" 144, "SOFT" 100, "WONK" 1;
  }
  @media (prefers-reduced-motion: reduce) {
    .obs-headline,
    .obs-numbers { animation: none; }
  }

  .tracked-row {
    grid-template-columns: minmax(0, 14rem) minmax(0, 1fr) 100px auto;
  }
  .tracked-row .trend {
    display: inline-flex;
    align-items: center;
    justify-content: flex-start;
    min-height: 22px;
  }
  @media (max-width: 640px) {
    .tracked-row {
      grid-template-columns: minmax(0, 1fr) auto;
    }
    .tracked-row .desc, .tracked-row .trend { display: none; }
  }
</style>
