---
import fs from 'node:fs';
import path from 'node:path';
import { getCollection } from 'astro:content';
import Layout from '../layouts/Layout.astro';
import { THEMES } from '../data/themes';
import Heatmap from '../components/charts/Heatmap.astro';

const articles = (await getCollection('articles', ({ data }) => !data.draft && !data.archived))
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());

const allCompanies = (await getCollection('companies'))
  .sort((a, b) => a.data.name.localeCompare(b.data.name));
const companies = allCompanies.filter((c) => c.data.aiRelevance !== 'non_ai');

// Per-company × per-theme matrix, computed at build time from the latest
// snapshot per company. Powers the homepage heatmap (the page's data anchor)
// and the stats / themes summaries below.
const SNAPSHOTS = path.resolve(process.cwd(), 'data', 'snapshots');
const matrixCells: { row: string; col: string; value: number }[] = [];
const companyTotals = new Map<string, number>();
const themeTotals = new Map<string, number>();
let panoramaPostings = 0;
let panoramaCompanies = 0;
let latestSnapshotDate: string | null = null;

for (const c of companies) {
  const dir = path.join(SNAPSHOTS, c.id);
  if (!fs.existsSync(dir)) continue;
  const files = fs.readdirSync(dir).filter((f) => /^\d{4}-\d{2}-\d{2}\.json$/.test(f)).sort();
  if (!files.length) continue;
  const newest = files[files.length - 1];
  if (!latestSnapshotDate || newest > latestSnapshotDate) latestSnapshotDate = newest;
  const snap = JSON.parse(fs.readFileSync(path.join(dir, newest), 'utf8'));
  const jobs = (snap.jobs ?? []) as { title?: string }[];
  panoramaCompanies++;
  panoramaPostings += snap.count ?? jobs.length;
  companyTotals.set(c.id, jobs.length);
  for (const t of THEMES) {
    const count = jobs.filter((j) => t.regex.test(j.title || '')).length;
    if (count > 0) {
      matrixCells.push({ row: c.id, col: t.slug, value: count });
      themeTotals.set(t.slug, (themeTotals.get(t.slug) ?? 0) + count);
    }
  }
}

const themeStats = THEMES.map((t) => ({
  ...t,
  total: themeTotals.get(t.slug) ?? 0,
}));

// Heatmap: companies sorted by fetched-role count, themes in canonical order
const fetchedCompanies = companies.filter((c) => (companyTotals.get(c.id) ?? 0) > 0);
fetchedCompanies.sort((a, b) => (companyTotals.get(b.id) ?? 0) - (companyTotals.get(a.id) ?? 0));
const heatmapRows = fetchedCompanies.map((c) => ({ id: c.id, label: c.data.name }));
const heatmapCols = THEMES.map((t) => ({ id: t.slug, label: t.name }));
const fmtSnapDate = (s: string | null) => s ? s.replace('.json', '').replaceAll('-', '.') : '—';

const description = 'Intent Alpha reads the public job boards of foundation labs, chip companies, and AI-adjacent platforms, and looks for what AI is becoming. Hypotheses with the hiring signals they rest on.';

const fmtDate = (d: Date) => d.toISOString().slice(0, 10).replace(/-/g, '.');
---
<Layout title="Intent Alpha" description={description} bgEquations={["e^(iπ) + 1 = 0", "L = − Σᵢ yᵢ log ŷᵢ"]}>
  <section class="hero">
    <svg class="hero-spiral" viewBox="0 0 144 89" preserveAspectRatio="xMidYMid slice" aria-hidden="true">
      <g class="grid">
        <rect x="0" y="0" width="144" height="89"/>
        <line x1="89" y1="0" x2="89" y2="89"/>
        <line x1="89" y1="55" x2="144" y2="55"/>
        <line x1="110" y1="55" x2="110" y2="89"/>
        <line x1="89" y1="68" x2="110" y2="68"/>
        <line x1="102" y1="55" x2="102" y2="68"/>
        <line x1="102" y1="63" x2="110" y2="63"/>
        <line x1="105" y1="63" x2="105" y2="68"/>
      </g>
      <path class="curve" pathLength="100" d="M 0 89 A 89 89 0 0 1 89 0 A 55 55 0 0 1 144 55 A 34 34 0 0 1 110 89 A 21 21 0 0 1 89 68 A 13 13 0 0 1 102 55 A 8 8 0 0 1 110 63 A 5 5 0 0 1 105 68 A 3 3 0 0 1 102 65 A 2 2 0 0 1 104 67"/>
    </svg>
    <span class="meta meta--accent">An editorial register on hiring as strategy</span>
    <h1 class="hero-art" aria-label="What companies are building next.">
      <span class="line line-1"><em>What</em></span>
      <span class="line line-2">
        companies
        <svg class="swash" viewBox="0 0 200 8" preserveAspectRatio="none" aria-hidden="true">
          <path d="M2,5.5 C30,2 70,7.2 110,4.8 C150,2.4 180,6.5 198,3.2"/>
        </svg>
      </span>
      <span class="line line-3"><em>are building</em></span>
      <span class="line line-4">next<span class="period">.</span></span>
    </h1>
    <p class="lede">
      We read the public job boards of foundation labs, chip companies, and
      AI-adjacent platforms, and look for <em>what AI is becoming</em>. Every
      dispatch is an explicit hypothesis grounded in hiring signals; every
      theme aggregates them across the field.
    </p>
  </section>

  <section class="stats">
    <div class="item">
      <span class="num">{panoramaCompanies}</span>
      <span class="lbl">AI companies in panorama</span>
    </div>
    <div class="item">
      <span class="num">{panoramaPostings.toLocaleString()}</span>
      <span class="lbl">Open roles aggregated</span>
    </div>
    <div class="item">
      <span class="num"><em>{THEMES.length}</em></span>
      <span class="lbl">Themes mapped</span>
    </div>
    <div class="item">
      <span class="num">{articles.length}</span>
      <span class="lbl">Dispatches published</span>
    </div>
  </section>

  <div class="section-head">
    <h2>The Panorama</h2>
    <a href="/themes/" class="count" style="text-decoration: none;">All {THEMES.length} themes →</a>
  </div>
  <p class="meta" style="margin-bottom: 1.5rem; color: var(--fg-muted); text-transform: none; letter-spacing: 0;">
    Where the field puts its hires. {fetchedCompanies.length} companies × {THEMES.length} themes; cell shade is role count tagged by theme regex (cream → vermillion). Click any cell to open the theme; hover to read the count. Snapshots through {fmtSnapDate(latestSnapshotDate)}.
  </p>
  <Heatmap
    rows={heatmapRows}
    cols={heatmapCols}
    cells={matrixCells}
    cellHref={(_rowId, colId) => `/themes/${colId}/`}
  />
  <p class="meta" style="margin: 0.85rem 0 1.5rem; color: var(--fg-muted); text-transform: none; letter-spacing: 0; text-align: right;">
    f(company, theme) = matching roles · fill ∝ count^0.55
  </p>

  <div class="section-head">
    <h2>Latest Dispatches</h2>
    <span class="count">{articles.length} of {articles.length}</span>
  </div>
  {articles.length === 0 && (
    <p class="meta" style="padding: 1.5rem 0;">No dispatches yet — first ones land soon.</p>
  )}
  <div class="dispatch-list">
    {articles.map((a) => (
      <a class="dispatch" href={`/articles/${a.id}/`}>
        <div class="meta-col">
          <span class="meta meta--accent">{a.data.cycle ? `Cycle №${a.data.cycle}` : 'Cycle —'}</span>
          <span class="meta">{fmtDate(a.data.publishedAt)}</span>
          <span class="meta" style="color: var(--fg-soft);">{a.data.company}</span>
        </div>
        <div>
          <h3>{a.data.title}</h3>
          <p class="desc">{a.data.description}</p>
        </div>
        <div class="stamp-col">
          <span class={`stamp stamp--${a.data.confidence}`}>
            <span class="v">{a.data.confidence}</span>
            <span class="h">{a.data.horizon}</span>
          </span>
        </div>
      </a>
    ))}
  </div>

  <div class="section-head">
    <h2>Tracked</h2>
    <span class="count">№ 01–{String(companies.length).padStart(2, '0')}</span>
  </div>
  <div class="list-rows">
    {companies.map((c, i) => (
      <a class="list-row" href={`/companies/${c.id}/`}>
        <span class="name">{c.data.name}</span>
        <span class="desc">{c.data.sector ?? c.data.description.slice(0, 80)}</span>
        <span class="num">№ {String(i + 1).padStart(2, '0')}</span>
      </a>
    ))}
  </div>
</Layout>
