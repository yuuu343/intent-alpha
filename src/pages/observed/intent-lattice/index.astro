---
// /observed/intent-lattice/ — index across 4 frontier labs.
// Compact lattice per lab + Q4 highlight.

import Layout from '../../../layouts/Layout.astro';
import Lattice from '../../../components/charts/Lattice.astro';
import fs from 'node:fs';
import path from 'node:path';

const LABS = ['anthropic', 'openai', 'cohere', 'mistral'];

type Topic = {
  topic: string;
  jobs: number;
  arxiv: number;
  quadrant: 'Q1' | 'Q2' | 'Q3' | 'Q4';
};
type LatticeData = {
  lab: string;
  computedAt: string;
  totals: { jobs: number; researchJobs: number; arxiv: number };
  thresholds: { jobs: number; arxiv: number };
  topics: Topic[];
};

function loadLattice(lab: string): LatticeData | null {
  const dir = path.resolve(process.cwd(), 'data', 'intent-lattice', lab);
  if (!fs.existsSync(dir)) return null;
  const files = fs.readdirSync(dir).filter((f) => /^\d{4}-\d{2}-\d{2}\.json$/.test(f)).sort();
  if (!files.length) return null;
  return JSON.parse(fs.readFileSync(path.join(dir, files[files.length - 1]), 'utf8'));
}

const lattices: { lab: string; data: LatticeData | null }[] = LABS.map((lab) => ({
  lab,
  data: loadLattice(lab),
}));

const TOPIC_LABEL: Record<string, string> = {
  post_training: 'post-training',
  pre_training: 'pre-training',
  interpretability: 'interpretability',
  alignment_safety: 'alignment',
  agents: 'agents',
  inference_serving: 'inference',
  multimodal: 'multimodal',
  evaluation: 'evaluation',
  compute_infra: 'compute',
  data_quality: 'data',
  security_eng: 'security',
  applied_fde: 'applied AI',
};
---
<Layout
  title="intent–alpha lattice — 4 frontier labs"
  description="What the frontier AI labs hire vs what they publish — the intent–alpha lattice across Anthropic, OpenAI, Cohere, Mistral."
  spineGlyph="◉"
  bgEquation="L(t) = ⟨ Do(t), Say(t) ⟩"
>
  <main class="lat-idx-main">
    <section class="lat-idx-hero">
      <p class="lat-idx-tag">α · observed · intent–alpha lattice</p>
      <h1 class="lat-idx-title">
        <em>The say-do gap,</em><br/>
        <em>made spatial.</em>
      </h1>
      <p class="lat-idx-lede">
        For each of four frontier labs, twelve research topics positioned by
        what the lab hires for (Do, x-axis) versus what the lab publishes (Say,
        y-axis). The most editorially interesting quadrant is Q4 — topics where
        hiring leads publishing, the loudest say-do gap.
      </p>
    </section>

    {lattices.map(({ lab, data }) => {
      const labCap = lab.charAt(0).toUpperCase() + lab.slice(1);
      if (!data) {
        return (
          <section class="lat-idx-lab">
            <h2 class="lat-idx-lab-h"><a href={`/observed/intent-lattice/${lab}/`}>{labCap}</a></h2>
            <p class="lat-idx-lab-pending">data populating — run scripts/intent-lattice.mjs {lab}</p>
          </section>
        );
      }
      const sayMissing = data.totals.arxiv === 0;
      if (sayMissing) {
        const topJobs = data.topics.filter((t) => t.jobs > 0).sort((a, b) => b.jobs - a.jobs).slice(0, 5);
        return (
          <section class="lat-idx-lab">
            <h2 class="lat-idx-lab-h">
              <a href={`/observed/intent-lattice/${lab}/`}>{labCap}</a>
              <span class="lat-idx-lab-meta">{data.totals.researchJobs} jobs · arxiv pending</span>
            </h2>
            <p class="lat-idx-lab-pending">Say axis (arxiv) data pending — fetch rate-limited, retry queued. Top hiring topics:</p>
            <p class="lat-idx-q4">
              {topJobs.map((t, i) => (
                <span>
                  {i > 0 && ' · '}
                  <strong>{TOPIC_LABEL[t.topic] ?? t.topic}</strong> ({t.jobs})
                </span>
              ))}
            </p>
            <p class="lat-idx-link"><a href={`/observed/intent-lattice/${lab}/`}>See {labCap} jobs distribution → </a></p>
          </section>
        );
      }
      const q4 = data.topics.filter((t) => t.quadrant === 'Q4').sort((a, b) => b.jobs - a.jobs);
      return (
        <section class="lat-idx-lab">
          <h2 class="lat-idx-lab-h">
            <a href={`/observed/intent-lattice/${lab}/`}>{labCap}</a>
            <span class="lat-idx-lab-meta">{data.totals.researchJobs} jobs · {data.totals.arxiv} papers</span>
          </h2>
          <Lattice
            lab={lab}
            topics={data.topics}
            thresholds={data.thresholds}
            totals={data.totals}
            compact={true}
          />
          {q4.length > 0 && (
            <p class="lat-idx-q4">
              <span class="lat-idx-q4-label">Q4 — hiring leads publishing:</span>
              {q4.map((t, i) => (
                <span>
                  {i > 0 && ' · '}
                  <strong>{TOPIC_LABEL[t.topic] ?? t.topic}</strong> ({t.jobs}j / {t.arxiv}p)
                </span>
              ))}
            </p>
          )}
          <p class="lat-idx-link"><a href={`/observed/intent-lattice/${lab}/`}>See {labCap} detail → </a></p>
        </section>
      );
    })}
  </main>
</Layout>

<style>
  .lat-idx-main {
    max-width: 1100px;
    margin: 0 auto;
    padding: 2.5rem 1.5rem 4rem;
  }
  .lat-idx-hero {
    margin-bottom: 2.5rem;
  }
  .lat-idx-tag {
    font-family: var(--font-mono);
    font-size: var(--fs-meta);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--fg-muted);
    margin: 0 0 1.4rem;
  }
  .lat-idx-title {
    font-family: var(--font-display);
    font-style: italic;
    font-variation-settings: "opsz" 144, "SOFT" 100, "WONK" 1;
    font-size: clamp(2rem, 6vw, 3.6rem);
    line-height: 1.1;
    margin: 0 0 1.5rem;
  }
  .lat-idx-lede {
    max-width: 56rem;
    font-size: 1.05rem;
    color: var(--fg-soft);
    margin: 0;
  }
  .lat-idx-lab {
    margin: 3rem 0;
    padding-top: 2rem;
    border-top: 1px solid var(--rule-soft);
  }
  .lat-idx-lab-h {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.8rem;
    margin: 0 0 1rem;
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
  }
  .lat-idx-lab-h a {
    color: var(--fg);
    text-decoration: none;
    font-style: italic;
  }
  .lat-idx-lab-h a:hover {
    color: var(--accent);
  }
  .lat-idx-lab-meta {
    font-family: var(--font-mono);
    font-style: normal;
    font-size: 0.78rem;
    color: var(--fg-muted);
    text-transform: uppercase;
    letter-spacing: 0.10em;
  }
  .lat-idx-lab-pending {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--fg-faint);
    margin: 1rem 0;
  }
  .lat-idx-q4 {
    margin: 1rem 0 0.5rem;
    font-size: 0.92rem;
    color: var(--fg-soft);
  }
  .lat-idx-q4-label {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    text-transform: uppercase;
    letter-spacing: 0.10em;
    color: var(--accent);
    margin-right: 0.6rem;
  }
  .lat-idx-q4 strong {
    color: var(--fg);
    font-weight: 600;
  }
  .lat-idx-link {
    margin: 0.6rem 0 0;
  }
  .lat-idx-link a {
    font-family: var(--font-display);
    font-style: italic;
    color: var(--accent);
    text-decoration: none;
  }
</style>
