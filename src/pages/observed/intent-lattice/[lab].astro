---
// /observed/intent-lattice/<lab>/ — per-lab intent–alpha lattice.
//
// Reads the precomputed lattice JSON for the lab (scripts/intent-lattice.mjs).
// Highlights Q4 (Do > Say — hiring leads publishing) as the editorially
// featured quadrant: that's where the say-do gap is loudest.

import Layout from '../../../layouts/Layout.astro';
import Lattice from '../../../components/charts/Lattice.astro';
import fs from 'node:fs';
import path from 'node:path';

const LABS = ['anthropic', 'openai', 'cohere', 'mistral'];

export async function getStaticPaths() {
  return [
    { params: { lab: 'anthropic' } },
    { params: { lab: 'openai' } },
    { params: { lab: 'cohere' } },
    { params: { lab: 'mistral' } },
  ];
}

const { lab } = Astro.params;

const dir = path.resolve(process.cwd(), 'data', 'intent-lattice', lab as string);
const files = fs.existsSync(dir)
  ? fs.readdirSync(dir).filter((f) => /^\d{4}-\d{2}-\d{2}\.json$/.test(f)).sort()
  : [];
const data = files.length > 0
  ? JSON.parse(fs.readFileSync(path.join(dir, files[files.length - 1]), 'utf8'))
  : null;

if (!data) {
  throw new Error(`no lattice data for ${lab} — run: node scripts/intent-lattice.mjs ${lab}`);
}

// Honest gate: if arxiv-side data is empty, the Y axis is a flat zero — every
// topic would land in Q4 by definition, which is misleading. Show a degraded
// state instead of a meaningless lattice.
const sayDataMissing = data.totals.arxiv === 0;

const TOPIC_LABEL: Record<string, string> = {
  post_training: 'post-training',
  pre_training: 'pre-training',
  interpretability: 'interpretability',
  alignment_safety: 'alignment',
  agents: 'agents',
  inference_serving: 'inference',
  multimodal: 'multimodal',
  evaluation: 'evaluation',
  compute_infra: 'compute',
  data_quality: 'data',
  security_eng: 'security',
  applied_fde: 'applied AI',
};

type LatticeTopic = {
  topic: string;
  jobs: number;
  arxiv: number;
  quadrant: 'Q1' | 'Q2' | 'Q3' | 'Q4';
  sampleJobs?: { title: string; url: string; department: string | null }[];
  sampleArxiv?: { title: string; url: string; published: string }[];
};

const topics: LatticeTopic[] = data.topics;
const q4 = topics.filter((t) => t.quadrant === 'Q4').sort((a, b) => b.jobs - a.jobs);
const q1 = topics.filter((t) => t.quadrant === 'Q1').sort((a, b) => (b.jobs + b.arxiv) - (a.jobs + a.arxiv));
const q2 = topics.filter((t) => t.quadrant === 'Q2').sort((a, b) => b.arxiv - a.arxiv);

const labCap = (lab as string).charAt(0).toUpperCase() + (lab as string).slice(1);

const otherLabs = LABS.filter((l) => l !== lab);
---
<Layout
  title={`${labCap} · intent–alpha lattice`}
  description={`What ${labCap} hires vs what ${labCap} publishes — the intent–alpha lattice across 12 research topics.`}
  spineGlyph="◉"
  bgEquation="L(t) = ⟨ Do(t), Say(t) ⟩"
>
  <main class="lat-main">
    <section class="lat-hero">
      <p class="lat-method-tag">α · observed · intent–alpha lattice · {labCap}</p>
      <h1 class="lat-title">
        <em>What {labCap} hires</em><br/>
        <em>vs what they publish.</em>
      </h1>
      <p class="lat-lede">
        Every dot is a research topic. The horizontal axis counts {labCap}'s open
        research/engineering roles that mention the topic; the vertical axis
        counts {labCap}-authored arxiv papers. Where a dot lands says something
        about whether the lab is talking about the topic, building it, both, or
        neither — the say-do gap, made spatial.
      </p>
    </section>

    {sayDataMissing ? (
      <section class="lat-pending">
        <h2 class="lat-pending-h">Say axis · data pending</h2>
        <p class="lat-pending-p">
          The Y axis (arxiv paper count) requires a per-entity arxiv snapshot
          for {labCap}; the latest fetch was rate-limited by the arxiv API and
          is queued for retry. Until that completes, only the Do (hiring)
          distribution is shown — the lattice quadrant assignment is omitted to
          avoid misleading every topic into Q4.
        </p>
        <p class="lat-pending-meta">
          Refresh after the next build cycle. <a href="/observed/intent-lattice/anthropic/">Anthropic lattice</a> has full Say + Do.
        </p>
        <h3 class="lat-pending-sub">Do — research/engineering hiring distribution</h3>
        <ul class="lat-do-list">
          {topics.filter((t) => t.jobs > 0).sort((a, b) => b.jobs - a.jobs).map((t) => (
            <li>
              <span class="lat-do-label">{TOPIC_LABEL[t.topic] ?? t.topic}</span>
              <span class="lat-do-bar" style={`--w: ${(t.jobs / Math.max(...topics.map((tt) => tt.jobs))) * 100}%`}></span>
              <span class="lat-do-count">{t.jobs}</span>
            </li>
          ))}
        </ul>
      </section>
    ) : (
      <section class="lat-chart">
        <Lattice
          lab={lab as string}
          topics={topics}
          thresholds={data.thresholds}
          totals={data.totals}
          caption={`${labCap} · ${data.totals.researchJobs} research/eng roles · ${data.totals.arxiv} papers · thresholds: jobs > ${data.thresholds.jobs}, papers > ${data.thresholds.arxiv}`}
        />
      </section>
    )}

    {!sayDataMissing && q4.length > 0 && (
      <section class="lat-quad-detail lat-quad-detail--featured">
        <h2 class="lat-quad-h">Q4 · Do &gt; Say <span class="lat-quad-h-sub">— hiring leads publishing</span></h2>
        <p class="lat-quad-explain">
          Topics where {labCap}'s hiring activity outpaces their public arxiv
          output. These are the areas where the lab is building faster than they
          are talking — a signal that infrastructure or product work is
          underway before the corresponding research narrative lands.
        </p>
        <ul class="lat-topic-list">
          {q4.map((t) => (
            <li class="lat-topic-item lat-topic-item--featured">
              <h3 class="lat-topic-h">{TOPIC_LABEL[t.topic] ?? t.topic}</h3>
              <p class="lat-topic-counts"><strong>{t.jobs}</strong> jobs · <strong>{t.arxiv}</strong> papers</p>
              {t.sampleJobs && t.sampleJobs.length > 0 && (
                <ul class="lat-sample-list">
                  {t.sampleJobs.slice(0, 3).map((j) => (
                    <li><a href={j.url} target="_blank" rel="noopener">{j.title}</a>{j.department && <span class="lat-sample-meta"> · {j.department}</span>}</li>
                  ))}
                </ul>
              )}
            </li>
          ))}
        </ul>
      </section>
    )}

    {!sayDataMissing && q1.length > 0 && (
      <section class="lat-quad-detail">
        <h2 class="lat-quad-h">Q1 · Say + Do <span class="lat-quad-h-sub">— core staffed research</span></h2>
        <p class="lat-quad-explain">
          Topics with both heavy publishing and heavy hiring. {labCap}'s
          publicly committed frontier.
        </p>
        <ul class="lat-topic-list">
          {q1.map((t) => (
            <li class="lat-topic-item">
              <h3 class="lat-topic-h">{TOPIC_LABEL[t.topic] ?? t.topic}</h3>
              <p class="lat-topic-counts"><strong>{t.jobs}</strong> jobs · <strong>{t.arxiv}</strong> papers</p>
            </li>
          ))}
        </ul>
      </section>
    )}

    {!sayDataMissing && q2.length > 0 && (
      <section class="lat-quad-detail">
        <h2 class="lat-quad-h">Q2 · Say &gt; Do <span class="lat-quad-h-sub">— discourse without fresh hiring</span></h2>
        <p class="lat-quad-explain">
          Topics where the lab publishes more than it currently hires for. Could
          mean the team is already staffed, the work shipped, or the topic
          functions more as discourse than active investment.
        </p>
        <ul class="lat-topic-list">
          {q2.map((t) => (
            <li class="lat-topic-item">
              <h3 class="lat-topic-h">{TOPIC_LABEL[t.topic] ?? t.topic}</h3>
              <p class="lat-topic-counts"><strong>{t.jobs}</strong> jobs · <strong>{t.arxiv}</strong> papers</p>
            </li>
          ))}
        </ul>
      </section>
    )}

    <section class="lat-method">
      <h2 class="lat-method-h">α · method</h2>
      <p>
        12 topic regexes (post-training, pre-training, interpretability, alignment,
        agents, inference, multimodal, evaluation, compute, data, security,
        applied AI). For each topic and each lab we count (a) research/engineering
        job postings whose title matches the topic regex (legal/sales/customer-
        success roles filtered out), and (b) arxiv papers from the lab's authors
        whose title or abstract matches the topic regex. Quadrants are defined
        by the median of non-zero values on each axis. Per-source regex variants
        tighten the arxiv side where bare keywords like <em>inference</em> or
        <em>multimodal</em> appear as background in unrelated papers; mapping
        precision was validated to ≥70% on every cell with n≥3 samples
        (<code>scripts/validate-mapping.mjs</code>).
      </p>
      <p class="lat-method-meta">
        sources: <code>{data.sources.jobs}</code>{data.sources.arxiv && <> · <code>{data.sources.arxiv}</code></>}<br/>
        computed: {new Date(data.computedAt).toISOString().slice(0, 10)}
      </p>
    </section>

    <section class="lat-other-labs">
      <h2 class="lat-other-h">Other labs</h2>
      <ul class="lat-other-list">
        {otherLabs.map((l) => (
          <li><a href={`/observed/intent-lattice/${l}/`}>{l.charAt(0).toUpperCase() + l.slice(1)} → </a></li>
        ))}
      </ul>
    </section>
  </main>
</Layout>

<style>
  .lat-main {
    max-width: 1100px;
    margin: 0 auto;
    padding: 2.5rem 1.5rem 4rem;
  }
  .lat-hero {
    margin-bottom: 2.5rem;
  }
  .lat-method-tag {
    font-family: var(--font-mono);
    font-size: var(--fs-meta);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--fg-muted);
    margin: 0 0 1.4rem;
  }
  .lat-title {
    font-family: var(--font-display);
    font-style: italic;
    font-variation-settings: "opsz" 144, "SOFT" 100, "WONK" 1;
    font-size: clamp(2rem, 6vw, 3.6rem);
    line-height: 1.1;
    margin: 0 0 1.5rem;
    color: var(--fg);
  }
  .lat-title em {
    font-style: italic;
  }
  .lat-lede {
    max-width: 56rem;
    font-size: 1.05rem;
    color: var(--fg-soft);
    margin: 0;
  }
  .lat-chart {
    margin: 2rem 0 3rem;
  }
  .lat-quad-detail {
    margin: 2.5rem 0;
    padding: 1.4rem 1.6rem;
    border-top: 1px solid var(--rule-soft);
  }
  .lat-quad-detail--featured {
    border-top: 2px solid var(--accent);
    background: rgba(192, 66, 26, 0.04);
  }
  .lat-quad-h {
    font-family: var(--font-display);
    font-style: italic;
    font-variation-settings: "opsz" 144, "SOFT" 60, "WONK" 1;
    font-size: 1.6rem;
    margin: 0 0 0.4rem;
    color: var(--fg);
  }
  .lat-quad-detail--featured .lat-quad-h {
    color: var(--accent);
  }
  .lat-quad-h-sub {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.10em;
    color: var(--fg-muted);
    font-style: normal;
    font-weight: 400;
    margin-left: 0.4rem;
  }
  .lat-quad-explain {
    max-width: 56rem;
    color: var(--fg-soft);
    margin: 0.4rem 0 1.2rem;
  }
  .lat-topic-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: grid;
    grid-template-columns: repeat(auto-fill, minmax(20rem, 1fr));
    gap: 1rem;
  }
  .lat-topic-item {
    padding: 0.9rem 1rem;
    background: var(--bg);
    border: 1px solid var(--rule-soft);
  }
  .lat-topic-item--featured {
    border-left: 3px solid var(--accent);
  }
  .lat-topic-h {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.05rem;
    margin: 0 0 0.2rem;
    font-variation-settings: "opsz" 60, "SOFT" 60, "WONK" 1;
    color: var(--fg);
  }
  .lat-topic-counts {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--fg-muted);
    margin: 0 0 0.6rem;
  }
  .lat-topic-counts strong {
    color: var(--accent);
  }
  .lat-sample-list {
    list-style: none;
    padding: 0;
    margin: 0;
    font-size: 0.85rem;
  }
  .lat-sample-list li {
    margin: 0.25rem 0;
    color: var(--fg-soft);
  }
  .lat-sample-list a {
    color: var(--fg);
    text-decoration: none;
    border-bottom: 1px dotted var(--accent);
  }
  .lat-sample-list a:hover {
    color: var(--accent);
  }
  .lat-sample-meta {
    color: var(--fg-faint);
    font-family: var(--font-mono);
    font-size: 0.7rem;
  }
  .lat-method {
    margin: 3rem 0 2rem;
    padding-top: 1.5rem;
    border-top: 1px solid var(--rule-soft);
  }
  .lat-method-h {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--fg-muted);
    margin: 0 0 0.8rem;
  }
  .lat-method p {
    color: var(--fg-soft);
    max-width: 60rem;
    margin: 0.4rem 0;
  }
  .lat-method-meta {
    font-family: var(--font-mono);
    font-size: 0.75rem;
    color: var(--fg-faint);
  }
  .lat-method-meta code {
    color: var(--fg-soft);
  }
  .lat-other-labs {
    margin-top: 2rem;
  }
  .lat-other-h {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--fg-muted);
    margin: 0 0 0.8rem;
  }
  .lat-other-list {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    gap: 2rem;
    flex-wrap: wrap;
  }
  .lat-other-list a {
    font-family: var(--font-display);
    font-style: italic;
    color: var(--fg);
    text-decoration: none;
    font-size: 1.05rem;
  }
  .lat-other-list a:hover {
    color: var(--accent);
  }
  .lat-pending {
    margin: 2rem 0 3rem;
    padding: 1.6rem 1.8rem;
    border: 1px solid var(--rule-soft);
    border-left: 3px solid var(--fg-muted);
  }
  .lat-pending-h {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.4rem;
    margin: 0 0 0.6rem;
    color: var(--fg);
  }
  .lat-pending-p {
    color: var(--fg-soft);
    max-width: 56rem;
    margin: 0.4rem 0;
  }
  .lat-pending-meta {
    font-family: var(--font-mono);
    font-size: 0.8rem;
    color: var(--fg-muted);
    margin: 0.4rem 0 1.4rem;
  }
  .lat-pending-meta a {
    color: var(--accent);
  }
  .lat-pending-sub {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    text-transform: uppercase;
    letter-spacing: 0.10em;
    color: var(--fg-muted);
    margin: 1.5rem 0 0.8rem;
    border-bottom: 1px solid var(--rule-soft);
    padding-bottom: 0.4rem;
  }
  .lat-do-list {
    list-style: none;
    padding: 0;
    margin: 0;
  }
  .lat-do-list li {
    display: grid;
    grid-template-columns: 9rem 1fr 3rem;
    align-items: center;
    gap: 0.9rem;
    padding: 0.4rem 0;
    border-bottom: 1px solid var(--rule-soft);
  }
  .lat-do-label {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 0.95rem;
    color: var(--fg-soft);
  }
  .lat-do-bar {
    height: 9px;
    background: var(--accent);
    width: var(--w, 0%);
    display: block;
  }
  .lat-do-count {
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--accent);
    text-align: right;
    font-weight: 600;
  }
</style>
