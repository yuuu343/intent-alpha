---
// α · observed — viz-first intermediate page.
//
// The homepage observation hero links here, not directly to PROV-010.
// This page exists to do one thing: show the data that backs the
// observation, in chart form, fast. Each section is one-line setup +
// big chart + one-line takeaway. Deep dispatch link only at the end.
//
// Topic: Anthropic is staffing vertical-specific Claude products that
// haven't been announced. Account Executives are already segmented by
// regulated industry; GitHub plugin packs are already shipping.

import Layout from '../../layouts/Layout.astro';
import BarChart from '../../components/charts/BarChart.astro';
import Sparkline from '../../components/charts/Sparkline.astro';
import fs from 'node:fs';
import path from 'node:path';

// ---- live data load --------------------------------------------------------
const SNAPSHOTS = path.resolve(process.cwd(), 'data', 'snapshots', 'anthropic');
const files = fs.existsSync(SNAPSHOTS)
  ? fs.readdirSync(SNAPSHOTS).filter((f) => /^\d{4}-\d{2}-\d{2}\.json$/.test(f)).sort()
  : [];
const latest = files.length > 0 ? JSON.parse(fs.readFileSync(path.join(SNAPSHOTS, files[files.length - 1]), 'utf8')) : { jobs: [] };
type Job = { id?: string | number; title?: string; department?: string | null; updated_at?: string | null; url?: string | null };
const jobs: Job[] = latest.jobs ?? [];

// ---- vertical AE breakdown -------------------------------------------------
type VerticalRow = { id: string; label: string; value: number; href?: string };
function countMatching(re: RegExp): number {
  return jobs.filter((j) => re.test(j.title || '')).length;
}
const verticalAEs: VerticalRow[] = [
  { id: 'federal',     label: 'Federal civilian',          value: countMatching(/federal civilian|account executive,?\s*federal/i) },
  { id: 'beneficial',  label: 'Beneficial Deployments',    value: countMatching(/beneficial deployments/i) },
  { id: 'industries',  label: 'Industries (generic vertical)', value: countMatching(/enterprise account executive,?\s*industries/i) },
  { id: 'life-sci',    label: 'Life Sciences',             value: countMatching(/strategic account executive,?\s*life sciences/i) },
  { id: 'healthcare',  label: 'Academic Medical Centers',  value: countMatching(/academic medical/i) },
  { id: 'manufacturing', label: 'Manufacturing & Automotive', value: countMatching(/manufacturing.*automotive|account executive,?\s*manufacturing/i) },
  { id: 'tech',        label: 'Tech',                      value: countMatching(/account executive,?\s*tech\b/i) },
  { id: 'startups',    label: 'Startups',                  value: countMatching(/account executive,?\s*startups/i) },
].filter((v) => v.value > 0).sort((a, b) => b.value - a.value);

const totalVerticalAE = verticalAEs.reduce((s, v) => s + v.value, 0);

// ---- GitHub vertical plugin packs -----------------------------------------
type PluginRow = { label: string; value: number; meta?: string };
let pluginPacks: PluginRow[] = [];
try {
  const ghDir = path.resolve(process.cwd(), 'data', 'github', 'anthropics');
  if (fs.existsSync(ghDir)) {
    const ghFiles = fs.readdirSync(ghDir).filter((f) => /^\d{4}-\d{2}-\d{2}\.json$/.test(f)).sort();
    if (ghFiles.length > 0) {
      const ghData = JSON.parse(fs.readFileSync(path.join(ghDir, ghFiles[ghFiles.length - 1]), 'utf8'));
      pluginPacks = (ghData.repos ?? [])
        .filter((r: any) => /-plugins$|^life-sciences$/.test(r.name))
        .map((r: any) => ({
          label: r.name,
          value: r.stars ?? 0,
          meta: r.language ?? '',
        }))
        .sort((a: PluginRow, b: PluginRow) => b.value - a.value);
    }
  }
} catch { /* tolerate */ }

// ---- Vertical AE trend across snapshots -----------------------------------
const verticalAERegex = /(federal civilian|beneficial deployments|enterprise account executive,?\s*industries|strategic account executive,?\s*life sciences|academic medical|manufacturing.*automotive|account executive,?\s*manufacturing|account executive,?\s*tech\b|account executive,?\s*startups)/i;
const trend: { date: string; value: number }[] = [];
for (const f of files) {
  try {
    const snap = JSON.parse(fs.readFileSync(path.join(SNAPSHOTS, f), 'utf8'));
    const count = (snap.jobs ?? []).filter((j: Job) => verticalAERegex.test(j.title || '')).length;
    trend.push({ date: f.replace('.json', ''), value: count });
  } catch { /* skip */ }
}

// ---- Headline: per-character entrance, mirrors equation watermark pattern.
// Each character gets a random direction and a hash-based stagger delay, so
// the headline materialises over ~2s like the equation watermarks rather
// than sliding in as one block. Same easing register as the rest of the site.
const headlineLines = [
  'Anthropic is staffing',
  'vertical-specific Claude products',
  "that haven't been announced.",
];
const headlineFull = headlineLines.join(' ');

// ---- Bit-output (typewriter-style) for the macro context paragraph and the
// number subtitle. Each character appears in reading order, left-to-right,
// at 4 ms stagger — fast, like a digital readout. Macro animates first, then
// the number subtitle starts after a short gap. Each character animates over
// 35 ms for a soft fade rather than a hard pop.
type BitSegment = { text: string; em?: boolean };
const macroSegments: BitSegment[] = [
  { text: 'The wider context: AI labs are crossing from horizontal model APIs to vertical industry solutions. Stripe did this with industry packs; Snowflake with data clouds; Palantir with embedded engineers. The transition shows up in ' },
  { text: 'sales architecture', em: true },
  { text: ' first — months or quarters before the products it supports are announced.' },
];
type BitChar = { ch: string; em: boolean };
const macroChars: BitChar[] = [];
for (const seg of macroSegments) {
  for (const ch of seg.text) macroChars.push({ ch, em: !!seg.em });
}
const macroFullText = macroSegments.map((s) => s.text).join('');

const subtitleText = `vertical Account Executive roles · already industry-segmented · pre-product staffing pattern (Stripe / Snowflake / Palantir all did this before launching vertical SKUs)`;

const BIT_STAGGER = 4;     // ms between consecutive chars (high-speed)
const BIT_INITIAL = 200;   // ms before first char of macro
const BIT_GAP = 200;       // ms between macro end and subtitle start
const macroEnd = BIT_INITIAL + macroChars.length * BIT_STAGGER;
const subtitleStart = macroEnd + BIT_GAP;

// ---- Compare to OpenAI (regional, not vertical) ---------------------------
let openaiRegional = 0;
let openaiTotal = 0;
try {
  const oaiDir = path.resolve(process.cwd(), 'data', 'snapshots', 'openai');
  if (fs.existsSync(oaiDir)) {
    const oaiFiles = fs.readdirSync(oaiDir).filter((f) => /^\d{4}-\d{2}-\d{2}\.json$/.test(f)).sort();
    if (oaiFiles.length > 0) {
      const oaiData = JSON.parse(fs.readFileSync(path.join(oaiDir, oaiFiles[oaiFiles.length - 1]), 'utf8'));
      const oaiJobs: Job[] = oaiData.jobs ?? [];
      openaiTotal = oaiJobs.length;
      // Account Director by region (Tokyo / Paris / Singapore / Sydney / Seoul / etc.) — region-segmented sales
      openaiRegional = oaiJobs.filter((j) => /account director/i.test(j.title || '')).length;
    }
  }
} catch { /* tolerate */ }
---
<Layout
  title="α · observed: Anthropic is staffing vertical-specific Claude products that haven't been announced"
  description="Anthropic's open roles show Account Executives segmented by Federal, Healthcare, Life Sciences, Manufacturing. GitHub plugin packs already shipping. The pre-product staffing pattern."
  spineGlyph="α"
  bgEquation={`vert_AE = ${totalVerticalAE}`}
>
  <a class="back" href="/">← α · home</a>

  <section class="obs-hero">
    <span class="meta meta--accent">α · observed 2026-04-30 · {jobs.length} open roles at anthropic</span>
    <p class="obs-macro" aria-label={macroFullText}>
      {macroChars.map((c, i) => {
        const delay = BIT_INITIAL + i * BIT_STAGGER;
        const style = `animation-delay: ${delay}ms;`;
        return c.em
          ? <em class="bit-ch" style={style} aria-hidden="true">{c.ch === ' ' ? ' ' : c.ch}</em>
          : <span class="bit-ch" style={style} aria-hidden="true">{c.ch === ' ' ? ' ' : c.ch}</span>;
      })}
    </p>
    <h1 class="obs-headline" aria-label={headlineFull}>
      {headlineLines.map((line, lineIdx) => (
        <span class={`obs-line-${lineIdx + 1}`}>
          {Array.from(line).map((ch, i) => {
            const k = i + (lineIdx + 1) * 31;
            const dir = ['from-top', 'from-bottom', 'from-left', 'from-right'][((k * 2654435761) >>> 0) % 4];
            const delay = (lineIdx * 180) + 250 + (((k * 7919) % 20) * 55);
            return (
              <span class={`obs-ch ${dir}`} style={`animation-delay: ${delay}ms;`} aria-hidden="true">
                {ch === ' ' ? ' ' : ch}
              </span>
            );
          })}
        </span>
      ))}
    </h1>
    <p class="obs-num">{totalVerticalAE}</p>
    <p class="obs-num-label" aria-label={subtitleText}>
      {Array.from(subtitleText).map((ch, i) => (
        <span class="bit-ch" style={`animation-delay: ${subtitleStart + i * BIT_STAGGER}ms;`} aria-hidden="true">{ch === ' ' ? ' ' : ch}</span>
      ))}
    </p>
  </section>

  <section class="viz-section">
    <div class="viz-setup">
      <span class="meta meta--accent">Chart 1 · the breakdown</span>
      <h2>Account Executives by vertical, today</h2>
    </div>
    <BarChart
      items={verticalAEs}
      caption={`f(vertical) = AE role count from job titles · source: data/snapshots/anthropic/${trend[trend.length - 1]?.date ?? ''}.json`}
    />
    <p class="viz-takeaway">
      <em>Six</em> distinct verticals with named-AE coverage today. Federal civilian
      and Beneficial Deployments tie for the largest band. <strong>None of these
      verticals have a corresponding announced Claude product</strong> — the sales
      motion precedes the product, by design.
    </p>
  </section>

  {pluginPacks.length > 0 && (
    <section class="viz-section">
      <div class="viz-setup">
        <span class="meta meta--accent">Chart 2 · the artifacts already shipping</span>
        <h2>GitHub vertical plugin packs, by stars</h2>
      </div>
      <BarChart
        items={pluginPacks}
        caption="GitHub repository stars · source: github.com/anthropics/ public repos matching /-plugins$|^life-sciences$/"
      />
      <p class="viz-takeaway">
        Three vertical plugin packs already exist as public repositories ── these
        are the developer-facing scaffolding that gets <strong>pre-installed once a
        vertical Claude product is announced</strong>. The sequence is consistent
        with the standard Stripe Press / Snowflake Marketplace pattern: ship the
        integration scaffolding first, name the product later.
      </p>
    </section>
  )}

  {trend.length >= 2 && (
    <section class="viz-section">
      <div class="viz-setup">
        <span class="meta meta--accent">Chart 3 · the trend</span>
        <h2>Vertical AE count, across snapshots</h2>
      </div>
      <div class="trend-large">
        <Sparkline points={trend} width={520} height={120} />
        <div class="trend-legend">
          <span><strong>{trend[0].value}</strong> on {trend[0].date}</span>
          <span style="color: var(--accent);"><strong>{trend[trend.length - 1].value}</strong> on {trend[trend.length - 1].date}</span>
          <span class="meta">delta: {trend[trend.length - 1].value - trend[0].value >= 0 ? '+' : ''}{trend[trend.length - 1].value - trend[0].value}</span>
        </div>
      </div>
      <p class="viz-takeaway">
        Day-over-day movement is small (single snapshot at start), but the pipeline
        is in place: vertical AE count is now tracked at every fetch. <strong>If
        the count climbs sharply over the next quarter, the vertical-product
        announcement is imminent.</strong>
      </p>
    </section>
  )}

  {openaiRegional > 0 && (
    <section class="viz-section">
      <div class="viz-setup">
        <span class="meta meta--accent">Chart 4 · the contrast</span>
        <h2>Anthropic segments by vertical. OpenAI segments by region.</h2>
      </div>
      <BarChart
        items={[
          { label: 'Anthropic — vertical AEs (Federal, Healthcare, Life Sci, Manufacturing, etc.)', value: totalVerticalAE, meta: `${jobs.length} total` },
          { label: 'OpenAI — regional Account Directors (Tokyo, Paris, etc.)', value: openaiRegional, meta: `${openaiTotal} total` },
        ]}
        labelWidth="22rem"
        caption="same Sales-heavy shape, different segmentation logic · source: data/snapshots/anthropic + data/snapshots/openai (latest)"
      />
      <p class="viz-takeaway">
        OpenAI's enterprise sales motion is <em>geography-anchored</em>; the
        product (the same API) ships across regions. Anthropic's is
        <em>industry-anchored</em>; the implication is that the products will
        differentiate by industry too. <strong>Vertical segmentation precedes
        vertical products. Regional segmentation precedes regional rollout of
        the same product.</strong> Different sales architecture, different product
        roadmap. This is a structural observation, not a competitive ranking.
      </p>
    </section>
  )}

  <section class="viz-section">
    <div class="viz-setup">
      <span class="meta meta--accent">Chart 5 · the watch windows</span>
      <h2>When to come back, and what to look for.</h2>
    </div>
    <div class="watch-timeline">
      <svg class="watch-svg" viewBox="0 0 1000 240" preserveAspectRatio="xMidYMid meet" role="img" aria-label="Observation windows from PROV-010 structured falsifications">
        {/* main timeline rule */}
        <line x1="80" y1="120" x2="920" y2="120" class="watch-rule"/>
        {/* anchor markers */}
        <g transform="translate(80, 120)">
          <circle r="9" class="watch-marker watch-marker--now"/>
          <text y="-22" text-anchor="start" class="watch-anchor">2026-04-30</text>
          <text y="-7" text-anchor="start" class="watch-anchor-sub">now · {totalVerticalAE} vertical AEs · {jobs.length} total roles</text>
        </g>
        <g transform="translate(560, 120)">
          <circle r="9" class="watch-marker"/>
          <text y="-22" text-anchor="middle" class="watch-anchor">2026-12-31</text>
          <text y="-7" text-anchor="middle" class="watch-anchor-sub">8 months out · falsification window 1</text>
          <text y="32" text-anchor="middle" class="watch-condition"><tspan x="0" dy="0">— Federal civilian contract $10M+ announced?</tspan></text>
          <text y="50" text-anchor="middle" class="watch-condition"><tspan x="0" dy="0">— Healthcare / Life Sciences named customer?</tspan></text>
          <text y="68" text-anchor="middle" class="watch-condition"><tspan x="0" dy="0">— Consumer mass app launched (>1M MAU within 6mo)?</tspan></text>
        </g>
        <g transform="translate(920, 120)">
          <circle r="9" class="watch-marker"/>
          <text y="-22" text-anchor="end" class="watch-anchor">2027-04-30</text>
          <text y="-7" text-anchor="end" class="watch-anchor-sub">12 months out · falsification window 2</text>
          <text y="32" text-anchor="end" class="watch-condition"><tspan x="0" dy="0">— Vertical AEs below 12? (vs 26+ now)</tspan></text>
          <text y="50" text-anchor="end" class="watch-condition"><tspan x="0" dy="0">— Beneficial Deployments fewer than 5?</tspan></text>
          <text y="68" text-anchor="end" class="watch-condition"><tspan x="0" dy="0">— Plugin packs zero commits in 90d?</tspan></text>
        </g>
      </svg>
    </div>
    <p class="viz-takeaway">
      The dates are not Anthropic's roadmap; they are <em>our observation
      deadlines</em>. If by 2026-12 there is no Federal civilian or Healthcare /
      Life Sciences named-customer announcement, the vertical-Claude thesis
      weakens. If by 2027-04 the vertical AE count drops below 12, the thesis is
      functionally dead. <strong>Come back to check.</strong> Each window's
      pass/fail status is tracked at <a href="/track-record/">/track-record/</a>.
    </p>
  </section>

  <section class="deep-link-section">
    <div class="deep-link-frame">
      <span class="meta meta--accent">α · the full thesis</span>
      <h2>The 12–18 month forecast, with 8 falsification conditions.</h2>
      <p>
        This page showed the staffing pattern. The deep dispatch carries the
        full hypothesis on what Claude products will appear and when, the
        cross-reference with arXiv + GitHub + departmental staffing, the
        Beneficial Deployments (a)/(b) interpretation caveat, the OpenAI
        regional-vs-vertical staffing technical contrast, and the eight
        specific reversal conditions — each with a date and a measurable
        threshold.
      </p>
      <p class="deep-link-cta">
        <a href="/articles/anthropic-twelve-month-surfaces-2026-04/">→ PROV-010 · twelve-month surfaces forecast (4,852 words)</a>
      </p>
    </div>
  </section>
</Layout>

<style>
  /* viz-first page: charts dominate, text annotates. */
  .obs-hero {
    padding: 1rem 0 2.5rem;
    border-bottom: var(--rule-thick) solid var(--rule);
    isolation: isolate;
  }
  .obs-headline {
    font-family: var(--font-display);
    font-weight: 360;
    letter-spacing: -0.025em;
    line-height: 1.04;
    margin: 1.25rem 0 1.5rem;
    max-width: 32ch;
    font-variation-settings: "opsz" 144, "SOFT" 50, "WONK" 1;
  }
  /* per-char entrance — same register as the equation watermarks. Each .obs-ch
     animates from a hashed direction with a hashed delay; the headline
     materialises over ~2s instead of sliding in as one block. */
  .obs-headline .obs-ch {
    display: inline-block;
    animation-duration: 1200ms;
    animation-fill-mode: both;
    animation-timing-function: cubic-bezier(0.16, 1, 0.3, 1);
    will-change: transform, opacity;
  }
  .obs-headline .obs-ch.from-top    { animation-name: obs-from-top; }
  .obs-headline .obs-ch.from-bottom { animation-name: obs-from-bottom; }
  .obs-headline .obs-ch.from-left   { animation-name: obs-from-left; }
  .obs-headline .obs-ch.from-right  { animation-name: obs-from-right; }
  @keyframes obs-from-top {
    from { opacity: 0; transform: translateY(-0.8em) rotate(4deg); }
    to   { opacity: 1; transform: translateY(0) rotate(0); }
  }
  @keyframes obs-from-bottom {
    from { opacity: 0; transform: translateY(0.8em) rotate(-4deg); }
    to   { opacity: 1; transform: translateY(0) rotate(0); }
  }
  @keyframes obs-from-left {
    from { opacity: 0; transform: translateX(-0.7em) rotate(-3deg); }
    to   { opacity: 1; transform: translateX(0) rotate(0); }
  }
  @keyframes obs-from-right {
    from { opacity: 0; transform: translateX(0.7em) rotate(3deg); }
    to   { opacity: 1; transform: translateX(0) rotate(0); }
  }
  @media (prefers-reduced-motion: reduce) {
    .obs-headline .obs-ch { animation: none; }
  }
  .obs-line-1, .obs-line-3 {
    display: block;
    font-size: clamp(1.6rem, 4.4vw, 3rem);
    color: var(--fg-soft);
    font-style: italic;
    font-variation-settings: "opsz" 144, "SOFT" 100, "WONK" 1;
  }
  .obs-line-2 {
    display: block;
    font-size: clamp(2.2rem, 6.4vw, 4.6rem);
    color: var(--fg);
    margin: 0.05em 0;
    font-variation-settings: "opsz" 144, "SOFT" 30, "WONK" 1;
  }
  .obs-num {
    font-family: var(--font-display);
    font-variation-settings: "opsz" 144, "SOFT" 30, "WONK" 1;
    font-weight: 380;
    font-size: clamp(4rem, 10vw, 7.5rem);
    line-height: 0.95;
    letter-spacing: -0.04em;
    color: var(--accent);
    margin: 1.25rem 0 0.5rem;
    animation: inner-from-below 1400ms cubic-bezier(0.16, 1, 0.3, 1) 600ms both;
  }
  .obs-num-label {
    font-family: var(--font-display);
    font-style: italic;
    font-size: var(--fs-lead);
    line-height: 1.42;
    color: var(--fg-soft);
    max-width: 44rem;
    font-variation-settings: "opsz" 36, "SOFT" 50, "WONK" 0;
  }
  .obs-macro {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.05rem;
    line-height: 1.55;
    color: var(--fg-muted);
    max-width: 50rem;
    margin: 1rem 0 0;
    padding-left: 1rem;
    border-left: 2px solid var(--rule);
    font-variation-settings: "opsz" 36, "SOFT" 60, "WONK" 0;
  }
  .obs-macro em {
    color: var(--fg);
    font-variation-settings: "opsz" 36, "SOFT" 100, "WONK" 1;
  }

  /* bit-output: each character fades in over 35 ms in left-to-right reading
     order, with a 4 ms stagger between chars. Fast — total page time ~2.3 s
     for both paragraphs combined. The visual rhythm reads as a digital
     readout, not a typewriter (no cursor, no clack — just sequential reveal). */
  .bit-ch {
    display: inline-block;
    animation: bit-out 35ms ease-out both;
  }
  @keyframes bit-out {
    from { opacity: 0; }
    to   { opacity: 1; }
  }
  @media (prefers-reduced-motion: reduce) {
    .bit-ch { animation: none; }
  }

  .watch-timeline {
    padding: 1.5rem 0;
    border-top: 1px solid var(--rule-soft);
    border-bottom: 1px solid var(--rule-soft);
    overflow-x: auto;
  }
  .watch-svg {
    width: 100%;
    min-width: 720px;
    height: auto;
    display: block;
  }
  .watch-rule {
    stroke: var(--rule);
    stroke-width: 1;
    vector-effect: non-scaling-stroke;
  }
  .watch-marker {
    fill: var(--bg);
    stroke: var(--accent);
    stroke-width: 2;
    vector-effect: non-scaling-stroke;
  }
  .watch-marker--now {
    fill: var(--accent);
  }
  .watch-anchor {
    font-family: var(--font-mono);
    font-size: 13px;
    font-weight: 600;
    fill: var(--fg);
    letter-spacing: 0.04em;
  }
  .watch-anchor-sub {
    font-family: var(--font-mono);
    font-size: 10px;
    fill: var(--fg-muted);
    letter-spacing: 0.06em;
    text-transform: uppercase;
  }
  .watch-condition {
    font-family: var(--font-display);
    font-style: italic;
    font-size: 12px;
    fill: var(--fg-soft);
    font-variation-settings: "opsz" 36, "SOFT" 60, "WONK" 0;
  }

  .viz-section {
    margin-top: 3.5rem;
    padding-top: 0;
  }
  .viz-setup {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    margin-bottom: 1.25rem;
  }
  .viz-setup h2 {
    font-size: clamp(1.4rem, 3vw, 2rem);
    margin: 0;
    line-height: 1.15;
    font-variation-settings: "opsz" 144, "SOFT" 50, "WONK" 1;
  }
  .viz-takeaway {
    margin: 1rem 0 0;
    max-width: 44rem;
    font-family: var(--font-display);
    font-style: italic;
    font-size: 1.05rem;
    line-height: 1.55;
    color: var(--fg-soft);
    font-variation-settings: "opsz" 36, "SOFT" 50, "WONK" 0;
  }
  .viz-takeaway strong {
    color: var(--fg);
    font-style: normal;
    font-variation-settings: "opsz" 36, "SOFT" 30, "WONK" 1;
  }
  .viz-takeaway em {
    color: var(--accent);
  }

  .trend-large {
    padding: 1.5rem 0;
    border-top: 1px solid var(--rule-soft);
    border-bottom: 1px solid var(--rule-soft);
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .trend-large :global(.sparkline) {
    max-width: 100% !important;
    height: 120px !important;
  }
  .trend-legend {
    display: flex;
    gap: 2rem;
    font-family: var(--font-mono);
    font-size: 0.85rem;
    color: var(--fg-soft);
    flex-wrap: wrap;
  }
  .trend-legend strong { color: var(--fg); font-size: 1.1rem; font-weight: 600; }

  .deep-link-section {
    margin-top: 5rem;
    padding-top: 3rem;
    border-top: var(--rule-thick) solid var(--rule);
