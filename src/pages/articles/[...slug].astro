---
import { getCollection, render } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

export async function getStaticPaths() {
  const articles = await getCollection('articles');
  return articles.map((article) => ({
    params: { slug: article.id },
    props: { article },
  }));
}

const { article } = Astro.props;
const { Content } = await render(article);

const company = (await getCollection('companies')).find((c) => c.id === article.data.company);

const ATS_LABEL: Record<string, string> = {
  greenhouse: 'Greenhouse',
  lever: 'Lever',
  workday: 'Workday',
  ashby: 'Ashby',
  smartrecruiters: 'SmartRecruiters',
  custom: 'a custom',
};
const adapterName = company ? ATS_LABEL[company.data.ats] : null;

const fmtDate = (d: Date) => d.toISOString().slice(0, 10).replace(/-/g, '.');

// ---- A: tokenize title.
// Italicize words that match a frontmatter tag (case-insensitive); break out
// trailing punctuation so it can render in vermillion italic.
const tagSet = new Set((article.data.tags ?? []).map((t) => t.toLowerCase()));
type Token = { kind: 'italic' | 'plain'; text: string };
const rawTokens: string[] = article.data.title.match(/([A-Za-z0-9']+)|([^A-Za-z0-9']+)/g) ?? [];
const tokens: Token[] = rawTokens.map((t) => ({
  kind: /^[A-Za-z0-9']+$/.test(t) && tagSet.has(t.toLowerCase()) ? 'italic' : 'plain',
  text: t,
}));
let trailingPunct = '';
for (let i = tokens.length - 1; i >= 0; i--) {
  const tok = tokens[i];
  if (tok.kind !== 'plain') break;
  const m = tok.text.match(/^(.*?)([.?!:…]+)\s*$/);
  if (m) {
    tok.text = m[1];
    trailingPunct = m[2];
    break;
  }
  if (/\S/.test(tok.text)) break;
}

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Article',
  headline: article.data.title,
  description: article.data.description,
  datePublished: article.data.publishedAt.toISOString(),
  dateModified: (article.data.updatedAt ?? article.data.publishedAt).toISOString(),
  author: { '@type': 'Organization', name: 'Intent Alpha' },
  publisher: { '@type': 'Organization', name: 'Intent Alpha' },
  about: company ? { '@type': 'Organization', name: company.data.name, url: company.data.website } : undefined,
};
---
<Layout
  title={article.data.title}
  description={article.data.description}
  ogType="article"
  publishedAt={article.data.publishedAt}
  updatedAt={article.data.updatedAt}
  jsonLd={jsonLd}
  spineGlyph="§"
  bgEquation={article.data.equation}
>
  <a class="back" href="/articles/">All Dispatches</a>

  {!article.data.archived && (
    <div class="method-tag" aria-label="method">
      <span class="meta meta--accent">α · Method</span>
      <span class="method-tag-body">intent–alpha gap analysis · {company?.data.name ?? article.data.company}</span>
    </div>
  )}

  <header class="article-head">
    <div class="meta-line">
      <span class="meta meta--accent">{article.data.cycle ? `Cycle №${article.data.cycle}` : 'Cycle —'}</span>
      <span class="meta">{fmtDate(article.data.publishedAt)}</span>
      {company && (
        <a class="meta" href={`/companies/${company.id}/`} style="text-decoration: none;">
          {company.data.name}
        </a>
      )}
      {article.data.provId && <span class="meta" style="color: var(--fg-faint);">{article.data.provId}</span>}
    </div>

    <h1>
      {tokens.map((t) => (t.kind === 'italic' ? <em class="kicker">{t.text}</em> : t.text))}
      {trailingPunct && <span class="period">{trailingPunct}</span>}
    </h1>
    <p class="deck">{article.data.description}</p>
  </header>

  <div class="hypothesis-block">
    <div class="label">Hypothesis</div>
    <div>
      <div class="body">{article.data.hypothesis}</div>
      <div class="meta-row">
        <span class={`stamp stamp--${article.data.confidence}`}>
          <span class="v">{article.data.confidence}</span>
          <span class="h">{article.data.horizon}</span>
        </span>
        {article.data.signalCount && article.data.totalPostings && (
          <span class="meta" style="align-self: center;">
            {article.data.signalCount} <span style="color: var(--fg-faint);">/ {article.data.totalPostings}</span> postings
          </span>
        )}
      </div>
    </div>
  </div>

  <article class="prose">
    <Content />
  </article>

  <section class="sources">
    <div class="label">Method</div>
    <div>
      <p>
        Postings were pulled from {company ? company.data.name : article.data.company}'s
        public{adapterName ? ` ${adapterName}` : ''} job board on {fmtDate(article.data.publishedAt)},
        snapshotted to a version-controlled JSON file.
      </p>
      {article.data.signalCount !== undefined && article.data.totalPostings !== undefined && (
        <p>
          {article.data.signalCount} of {article.data.totalPostings} postings clustered as
          signal under this dispatch's regex; the cluster definition and the full posting
          set are captured in the snapshot file linked below.
        </p>
      )}
      <p>
        The confidence stamp ({article.data.confidence}, horizon {article.data.horizon})
        reflects the strength of inference within the tracked set. Structural coverage
        limits — bot-protected adapters, unresolved Workday tenants, categories absent
        from the roster — are listed at <a href="/coverage/">/coverage</a>. Both should
        be read together.
      </p>
      <p>
        Aggregation code and raw snapshots will be released as an open GitHub repository
        alongside the next deep dispatch. Until then, the snapshot files in this tree
        are the canonical record.
      </p>
    </div>
  </section>

  <section class="sources" style="margin-top: 2rem;">
    <div class="label">Sources</div>
    <div>
      <ul>
        {article.data.provId && <li>{article.data.provId} — Critic verdict: PASS</li>}
        {article.data.signalCount && article.data.totalPostings && (
          <li>{article.data.signalCount} of {article.data.totalPostings} postings clustered as signal</li>
        )}
        {company && <li>{company.data.name} public board ({company.data.ats})</li>}
        <li>Snapshot: data/snapshots/{article.data.company}/{article.data.publishedAt.toISOString().slice(0,10)}.json</li>
      </ul>
    </div>
  </section>
</Layout>

<style>
  .method-tag {
    display: inline-flex;
    align-items: baseline;
    gap: 0.7rem;
    margin: 0.5rem 0 1.5rem;
    padding: 0.4rem 0.7rem;
    border: 1px solid var(--rule);
    border-left: 2px solid var(--accent);
    background: var(--bg-deep);
  }
  .method-tag .method-tag-body {
    font-family: var(--font-mono);
    font-size: 0.78rem;
    color: var(--fg-soft);
  }
</style>
