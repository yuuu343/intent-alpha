---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const all = (await getCollection('articles', ({ data }) => !data.draft))
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());
const articles = all.filter((a) => !a.data.archived);
const archived = all.filter((a) => a.data.archived);

const fmtDate = (d: Date) => d.toISOString().slice(0, 10).replace(/-/g, '.');
---
<Layout title="Dispatches" description="All hypothesis dispatches from Intent Alpha — public hiring signals read as the field's direction.">
  <section class="hero" style="border-bottom: 0; padding-bottom: 1.5rem;">
    <span class="meta meta--accent">The Register</span>
    <h1>Dispatches</h1>
    <p class="lede">Every published hypothesis, with its signals and resolution criteria. Falsifiable by design.</p>
  </section>

  <div class="section-head">
    <h2>All Dispatches</h2>
    <span class="count">{articles.length} {articles.length === 1 ? 'entry' : 'entries'}</span>
  </div>

  <div class="dispatch-list">
    {articles.map((a) => (
      <a class="dispatch" href={`/articles/${a.id}/`}>
        <div class="meta-col">
          <span class="meta meta--accent">{a.data.cycle ? `Cycle №${a.data.cycle}` : 'Cycle —'}</span>
          <span class="meta">{fmtDate(a.data.publishedAt)}</span>
          <span class="meta" style="color: var(--fg-soft);">{a.data.company}</span>
        </div>
        <div>
          <h3>{a.data.title}</h3>
          <p class="desc">{a.data.description}</p>
        </div>
        <div class="stamp-col">
          <span class={`stamp stamp--${a.data.confidence}`}>
            <span class="v">{a.data.confidence}</span>
            <span class="h">{a.data.horizon}</span>
          </span>
        </div>
      </a>
    ))}
  </div>

  {archived.length > 0 && (
    <>
      <div class="section-head" style="margin-top: 4rem;">
        <h2>Archived (off-thesis)</h2>
        <span class="count">{archived.length} {archived.length === 1 ? 'entry' : 'entries'}</span>
      </div>
      <p class="meta" style="margin-bottom: 1.25rem; color: var(--fg-muted); text-transform: none; letter-spacing: 0;">
        Earlier dispatches that fell outside the AI-research register. Kept here because the
        URLs continue to resolve and the snapshot data remains reproducible.
      </p>
      <div class="dispatch-list">
        {archived.map((a) => (
          <a class="dispatch" href={`/articles/${a.id}/`} style="opacity: 0.7;">
            <div class="meta-col">
              <span class="meta">{a.data.cycle ? `Cycle №${a.data.cycle}` : 'Cycle —'}</span>
              <span class="meta">{fmtDate(a.data.publishedAt)}</span>
              <span class="meta" style="color: var(--fg-soft);">{a.data.company}</span>
            </div>
            <div>
              <h3>{a.data.title}</h3>
              <p class="desc">{a.data.description}</p>
            </div>
            <div class="stamp-col">
              <span class="meta" style="color: var(--fg-faint);">archived</span>
            </div>
          </a>
        ))}
      </div>
    </>
  )}
</Layout>
