---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';
import BarChart from '../../components/charts/BarChart.astro';
import Sparkline from '../../components/charts/Sparkline.astro';
import { THEMES } from '../../data/themes';
import fs from 'node:fs';
import path from 'node:path';

export async function getStaticPaths() {
  const companies = await getCollection('companies');
  return companies.map((company) => ({
    params: { slug: company.id },
    props: { company },
  }));
}

const { company } = Astro.props;

const articles = (await getCollection('articles', ({ data }) => !data.draft && data.company === company.id))
  .sort((a, b) => b.data.publishedAt.getTime() - a.data.publishedAt.getTime());

const fmtDate = (d: Date) => d.toISOString().slice(0, 10).replace(/-/g, '.');

// ---- B: read snapshots at build time for stats + breakdown viz + sparkline.
function loadCompanyData(slug: string) {
  const dir = path.resolve(process.cwd(), 'data', 'snapshots', slug);
  if (!fs.existsSync(dir)) return null;
  const files = fs.readdirSync(dir).filter((f) => /^\d{4}-\d{2}-\d{2}\.json$/.test(f)).sort();
  if (files.length === 0) return null;
  const latest = files[files.length - 1];
  // Build a tiny snapshot history (date + count per snapshot) for the sparkline.
  const history: { date: string; value: number }[] = [];
  for (const f of files) {
    try {
      const s = JSON.parse(fs.readFileSync(path.join(dir, f), 'utf8'));
      const count = typeof s.count === 'number' ? s.count : (Array.isArray(s.jobs) ? s.jobs.length : 0);
      history.push({ date: f.replace('.json', ''), value: count });
    } catch { /* skip */ }
  }
  try {
    const snap = JSON.parse(fs.readFileSync(path.join(dir, latest), 'utf8'));
    return { snap, latest, history };
  } catch {
    return null;
  }
}
type Job = { title?: string; department?: string | null; location?: string | null; updated_at?: string | null; url?: string | null };
const snapshot = loadCompanyData(company.id);
const jobs: Job[] = snapshot?.snap?.jobs ?? [];
const postings = typeof snapshot?.snap?.count === 'number' ? snapshot.snap.count : jobs.length || null;
const lastFetch = snapshot ? snapshot.latest.replace('.json', '').replaceAll('-', '.') : null;
const history = snapshot?.history ?? [];
const trendDelta = history.length >= 2 ? history[history.length - 1].value - history[0].value : 0;
const dispatchesCount = articles.length;
const signalsSum = articles.reduce((s, a) => s + (a.data.signalCount ?? 0), 0);

// Department breakdown (top 12 by count)
const deptCounts = new Map<string, number>();
for (const j of jobs) {
  const d = j.department ?? '(no department)';
  deptCounts.set(d, (deptCounts.get(d) ?? 0) + 1);
}
const topDepts = Array.from(deptCounts.entries())
  .sort((a, b) => b[1] - a[1])
  .slice(0, 12)
  .map(([label, value]) => ({ label, value, meta: `${((value / Math.max(jobs.length, 1)) * 100).toFixed(1)}%` }));

// Theme exposure: count of jobs per theme via theme regex on title
const themeExposure = THEMES.map((t) => ({
  id: t.slug,
  label: t.name,
  value: jobs.filter((j) => t.regex.test(j.title || '')).length,
  href: `/themes/${t.slug}/`,
})).filter((x) => x.value > 0).sort((a, b) => b.value - a.value);

// ---- Capability profile (3 derived scores from job titles).
// All counts come from titles only — no body, no external claim. Each metric
// is a structural signal about how the company is staffing, not a value
// judgment. Rendered as a single mono row above the Department breakdown.
const AGENT_RE = /(\bagent\b|agentic|orchestrat|autonomous|long[- ]?running|\bmcp\b|coordination)/i;
const FDE_RE = /(forward[- ]deployed|technical ambassador|solutions engineer|customer engineer|applied (?:ai|engineer|ml|architect))/i;
const RESEARCH_RE = /(research scientist|research engineer|\bphd\b|fellowship)/i;
const COMPLIANCE_RE = /(compliance|regulation|gdpr|hipaa|soc[- ]?2|sr 11-7|fedramp|fisma|trust and safety|safeguards|\bgrc\b|sovereign)/i;

const agenticCount = jobs.filter((j) => AGENT_RE.test(j.title || '')).length;
const fdeCount = jobs.filter((j) => FDE_RE.test(j.title || '')).length;
const researchCount = jobs.filter((j) => RESEARCH_RE.test(j.title || '')).length;
const complianceCount = jobs.filter((j) => COMPLIANCE_RE.test(j.title || '')).length;
const totalJobs = jobs.length;
const scores = {
  agenticPct: totalJobs ? (agenticCount / totalJobs * 100) : 0,
  compliancePct: totalJobs ? (complianceCount / totalJobs * 100) : 0,
  fdeRatio: researchCount > 0 ? (fdeCount / researchCount) : null,
};

// Default equation by AI relevance — soft topical hint when the company isn't
// the subject of an article yet.
const equationByRelevance: Record<string, string | undefined> = {
  ai_native:   'softmax(zᵢ) = exp(zᵢ) / Σⱼ exp(zⱼ)',
  ai_infra:    'n(t) = n₀ · 2^(t/T)',
  ai_adjacent: undefined,
  non_ai:      undefined,
};
const companyEquation = equationByRelevance[company.data.aiRelevance];

const jsonLd = {
  '@context': 'https://schema.org',
  '@type': 'Organization',
  name: company.data.name,
  url: company.data.website,
  description: company.data.description,
};

const host = new URL(company.data.website).host;
---
<Layout
  title={company.data.name}
  description={`Hiring-signal analysis and direction hypotheses for ${company.data.name}.`}
  jsonLd={jsonLd}
  spineGlyph="№"
  bgEquation={companyEquation}
>
  <a class="back" href="/companies/">All Companies</a>

  <header class="article-head">
    <div class="meta-line">
      <span class="meta meta--accent">Subject</span>
      <span class="meta">{company.data.ats.toUpperCase()}</span>
      {company.data.sector && <span class="meta">{company.data.sector}</span>}
      {company.data.headquarters && <span class="meta">{company.data.headquarters}</span>}
    </div>
    <h1>{company.data.name}</h1>
    <p class="deck">{company.data.description}</p>
    <p class="meta" style="margin-top: 1.5rem;">
      <a href={company.data.website} rel="noopener" style="color: var(--fg-muted); text-decoration-color: var(--rule);">{host}</a>
    </p>
  </header>

  <section class="stats stats--small">
    <div class="item">
      <span class="num">{postings ?? '—'}</span>
      <span class="lbl">Postings tracked</span>
    </div>
    <div class="item">
      <span class="num">{signalsSum > 0 ? <em>{signalsSum}</em> : '—'}</span>
      <span class="lbl">Signals isolated</span>
    </div>
    <div class="item">
      <span class="num">{dispatchesCount > 0 ? dispatchesCount : '—'}</span>
      <span class="lbl">Dispatches</span>
    </div>
    <div class="item">
      <span class="num num--date">{lastFetch ?? '—'}</span>
      <span class="lbl">Last fetch</span>
    </div>
  </section>

  {history.length >= 2 && (
    <div class="trend-row">
      <span class="meta meta--accent">Hiring trend</span>
      <Sparkline points={history}/>
      <span class="meta">
        {history[0].date} → {history[history.length - 1].date} · {history[history.length - 1].value.toLocaleString()} now ({trendDelta >= 0 ? '+' : ''}{trendDelta})
      </span>
    </div>
  )}

  {totalJobs > 0 && (
    <div class="scorecard-row">
      <span class="meta meta--accent">Capability profile</span>
      <span class="score-item">
        agentic <strong>{scores.agenticPct.toFixed(1)}%</strong>
        <span class="score-sub">{agenticCount}/{totalJobs}</span>
      </span>
      <span class="score-item">
        FDE/Research <strong>{scores.fdeRatio === null ? '—' : scores.fdeRatio.toFixed(2)}</strong>
        <span class="score-sub">{fdeCount}/{researchCount}</span>
      </span>
      <span class="score-item">
        compliance <strong>{scores.compliancePct.toFixed(1)}%</strong>
        <span class="score-sub">{complianceCount}/{totalJobs}</span>
      </span>
    </div>
  )}

  {topDepts.length > 0 && (
    <>
      <div class="section-head" style="margin-top: 2rem;">
        <h2>Department breakdown</h2>
        <span class="count">{deptCounts.size} departments · top {Math.min(12, deptCounts.size)}</span>
      </div>
      <BarChart
        items={topDepts}
        caption={`f(department) = roles tagged · share of ${jobs.length.toLocaleString()} open postings`}
      />
    </>
  )}

  {themeExposure.length > 0 && (
    <>
      <div class="section-head" style="margin-top: 2.5rem;">
        <h2>Theme exposure</h2>
        <span class="count">{themeExposure.length} of {THEMES.length} themes matched</span>
      </div>
      <BarChart
        items={themeExposure}
        caption={`g(theme) = roles matching theme regex (linked to theme detail)`}
      />
    </>
  )}

  <div class="section-head" style="margin-top: 2.5rem;">
    <h2>Dispatches on {company.data.name}</h2>
    <span class="count">{articles.length} {articles.length === 1 ? 'entry' : 'entries'}</span>
  </div>

  {articles.length === 0 && (
    <p class="meta" style="padding: 1.5rem 0;">No dispatches yet for {company.data.name}. Stay tuned.</p>
  )}

  <div class="dispatch-list">
    {articles.map((a) => (
      <a class="dispatch" href={`/articles/${a.id}/`}>
        <div class="meta-col">
          <span class="meta meta--accent">{a.data.cycle ? `Cycle №${a.data.cycle}` : 'Cycle —'}</span>
          <span class="meta">{fmtDate(a.data.publishedAt)}</span>
        </div>
        <div>
          <h3>{a.data.title}</h3>
          <p class="desc">{a.data.description}</p>
        </div>
        <div class="stamp-col">
          <span class={`stamp stamp--${a.data.confidence}`}>
            <span class="v">{a.data.confidence}</span>
            <span class="h">{a.data.horizon}</span>
          </span>
        </div>
      </a>
    ))}
  </div>
</Layout>

<style>
  .trend-row {
    display: flex;
    align-items: center;
    gap: 1rem;
    flex-wrap: wrap;
    padding: 1rem 0 0.5rem;
    margin-top: 0.5rem;
    border-top: 1px solid var(--rule-soft);
  }
  .trend-row .meta { white-space: nowrap; }

  .scorecard-row {
    display: flex;
    align-items: baseline;
    gap: 1.5rem 2rem;
    flex-wrap: wrap;
    padding: 0.5rem 0 0.85rem;
    border-bottom: 1px solid var(--rule-soft);
    font-family: var(--font-mono);
    font-size: 0.85rem;
  }
  .score-item {
    display: inline-flex;
    align-items: baseline;
    gap: 0.4rem;
    color: var(--fg-soft);
    text-transform: lowercase;
    letter-spacing: 0.04em;
  }
  .score-item strong {
    font-weight: 600;
    color: var(--accent);
    font-size: 1rem;
  }
  .score-item .score-sub {
    font-size: 0.7rem;
    color: var(--fg-faint);
    letter-spacing: 0.06em;
  }
</style>
