---
import { getCollection } from 'astro:content';
import Layout from '../../layouts/Layout.astro';

const companies = (await getCollection('companies'))
  .sort((a, b) => a.data.name.localeCompare(b.data.name));
---
<Layout title="Companies" description="Companies tracked by Intent Alpha.">
  <h1>Companies</h1>
  <p class="muted">{companies.length} tracked.</p>
  <ul>
    {companies.map((c) => (
      <li>
        <a href={`/companies/${c.id}`}>{c.data.name}</a>
        {c.data.sector && <span class="muted"> — {c.data.sector}</span>}
      </li>
    ))}
  </ul>
</Layout>
